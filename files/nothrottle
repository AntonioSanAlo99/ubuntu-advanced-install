# ============================================================================
# INSTALACIÓN / DESINSTALACIÓN DEL SISTEMA
# ============================================================================

INSTALL_BIN="/usr/local/bin/nothrottle"
INSTALL_APPLY="/usr/local/bin/nothrottle-apply"
INSTALL_MAN="/usr/local/share/man/man8/nothrottle.8"
INSTALL_DESKTOP="/usr/share/applications/nothrottle.desktop"

do_install() {
    echo ""
    echo -e "${BOLD}${CYAN}═══════════════════════════════════════════════════════════════${NC}"
    echo -e "${BOLD}${CYAN}  INSTALACIÓN - NoThrottle v${VERSION}${NC}"
    echo -e "${BOLD}${CYAN}═══════════════════════════════════════════════════════════════${NC}"
    echo ""

    # Copiar binario principal
    echo -n "  Instalando binario... "
    cp "$SCRIPT_PATH" "$INSTALL_BIN"
    chmod 755 "$INSTALL_BIN"
    echo -e "${GREEN}✓${NC} $INSTALL_BIN"

    # Crear directorio de configuración
    echo -n "  Creando configuración... "
    mkdir -p "$CONFIG_DIR"
    echo -e "${GREEN}✓${NC} $CONFIG_DIR/"

    # Crear script de aplicación en boot
    echo -n "  Instalando aplicador de boot... "
    create_startup_service
    echo -e "${GREEN}✓${NC} $INSTALL_APPLY"

    # Crear man page
    echo -n "  Instalando man page... "
    install_manpage
    echo -e "${GREEN}✓${NC} $INSTALL_MAN"

    # Crear .desktop para GNOME
    echo -n "  Creando acceso desde escritorio... "
    install_desktop_entry
    echo -e "${GREEN}✓${NC} $INSTALL_DESKTOP"

    # Verificar dependencias opcionales
    echo ""
    echo -e "${BOLD}  Dependencias:${NC}"
    check_install_dep "intel-undervolt" "Undervolt de CPU" "apt install intel-undervolt"
    check_install_dep "msr-tools" "Ajuste de PROCHOT via MSR" "apt install msr-tools"
    check_install_dep "lm-sensors" "Monitoreo de temperaturas" "apt install lm-sensors"

    echo ""
    echo -e "${GREEN}✓✓✓ Instalación completada ✓✓✓${NC}"
    echo ""
    echo -e "  Uso:"
    echo -e "    ${CYAN}sudo nothrottle${NC}          Interfaz interactiva (TUI)"
    echo -e "    ${CYAN}sudo nothrottle --apply${NC}   Aplicar configuración guardada"
    echo -e "    ${CYAN}sudo nothrottle --status${NC}  Ver estado actual"
    echo -e "    ${CYAN}sudo nothrottle --help${NC}    Ayuda completa"
    echo ""
}

do_uninstall() {
    echo ""
    echo -e "${BOLD}${RED}═══════════════════════════════════════════════════════════════${NC}"
    echo -e "${BOLD}${RED}  DESINSTALACIÓN - NoThrottle${NC}"
    echo -e "${BOLD}${RED}═══════════════════════════════════════════════════════════════${NC}"
    echo ""

    echo -e "${YELLOW}Se eliminarán:${NC}"
    [ -f "$INSTALL_BIN" ] && echo "  • $INSTALL_BIN"
    [ -f "$INSTALL_APPLY" ] && echo "  • $INSTALL_APPLY"
    [ -f "$STARTUP_SCRIPT" ] && echo "  • $STARTUP_SCRIPT"
    [ -f "$INSTALL_MAN" ] && echo "  • $INSTALL_MAN"
    [ -f "$INSTALL_DESKTOP" ] && echo "  • $INSTALL_DESKTOP"
    echo ""
    echo -e "${YELLOW}NO se eliminará:${NC}"
    echo "  • $CONFIG_DIR/ (tu configuración se conserva)"
    echo ""

    read -p "¿Confirmar desinstalación? (s/n) [n]: " confirm
    confirm=${confirm:-n}
    if [ "$confirm" != "s" ] && [ "$confirm" != "S" ]; then
        echo -e "${YELLOW}Desinstalación cancelada${NC}"
        return 1
    fi

    # Deshabilitar servicio
    if systemctl is-enabled nothrottle &>/dev/null; then
        echo -n "  Deshabilitando servicio... "
        systemctl disable nothrottle 2>/dev/null
        systemctl stop nothrottle 2>/dev/null || true
        echo -e "${GREEN}✓${NC}"
    fi

    # Eliminar archivos
    for f in "$INSTALL_BIN" "$INSTALL_APPLY" "$STARTUP_SCRIPT" "$INSTALL_MAN" "$INSTALL_DESKTOP"; do
        if [ -f "$f" ]; then
            echo -n "  Eliminando $f... "
            rm -f "$f"
            echo -e "${GREEN}✓${NC}"
        fi
    done

    systemctl daemon-reload 2>/dev/null
    mandb -q 2>/dev/null || true

    echo ""
    echo -e "${GREEN}✓ Desinstalación completada${NC}"
    echo -e "  Configuración conservada en: $CONFIG_DIR/"
    echo -e "  Para eliminarla: ${CYAN}sudo rm -rf $CONFIG_DIR${NC}"
    echo ""
}

do_status() {
    echo ""
    echo -e "${BOLD}${CYAN}NoThrottle v${VERSION} — Estado${NC}"
    echo ""

    # Instalación
    echo -e "${BOLD}Instalación:${NC}"
    if [ -f "$INSTALL_BIN" ]; then
        local installed_ver
        installed_ver=$("$INSTALL_BIN" --version 2>/dev/null || echo "?")
        echo -e "  Binario:   ${GREEN}✓${NC} $INSTALL_BIN (v${installed_ver})"
    else
        echo -e "  Binario:   ${RED}✗${NC} No instalado"
    fi
    [ -f "$INSTALL_APPLY" ] && echo -e "  Aplicador: ${GREEN}✓${NC} $INSTALL_APPLY" || echo -e "  Aplicador: ${RED}✗${NC}"
    [ -d "$CONFIG_DIR" ] && echo -e "  Config:    ${GREEN}✓${NC} $CONFIG_DIR/" || echo -e "  Config:    ${YELLOW}—${NC} Sin configuración guardada"
    echo ""

    # Servicio
    echo -e "${BOLD}Servicio systemd:${NC}"
    if systemctl is-enabled nothrottle &>/dev/null; then
        echo -e "  Estado:    ${GREEN}✓ Habilitado${NC} (aplica en cada boot)"
    else
        echo -e "  Estado:    ${YELLOW}— Deshabilitado${NC} (no aplica en boot)"
    fi
    echo ""

    # Hardware
    detect_cpu
    detect_cores
    detect_tjmax
    CPUINFO_MAX=$(cat /sys/devices/system/cpu/cpu0/cpufreq/cpuinfo_max_freq 2>/dev/null || echo "0")
    CPUINFO_MAX=$((CPUINFO_MAX / 1000))
    read_current_undervolt
    read_current_power
    read_current_freq
    read_current_temps

    echo -e "${BOLD}Hardware:${NC}"
    echo -e "  CPU:       ${GREEN}$CPU_MODEL${NC}"
    echo -e "  Gen:       ${GREEN}$CPU_GEN${NC}"
    if [ "$HAS_HYBRID" = true ]; then
        echo -e "  Cores:     ${GREEN}${P_CORES}P + ${E_CORES}E${NC} (${CPU_CORES} total)"
    else
        echo -e "  Cores:     ${GREEN}$CPU_CORES${NC}"
    fi
    echo -e "  Tjmax:     ${GREEN}${TJMAX}°C${NC}"
    echo -e "  Temp:      ${GREEN}${CPU_TEMP}°C${NC}"
    echo ""

    echo -e "${BOLD}Configuración activa:${NC}"
    echo -e "  Undervolt: CPU=${GREEN}${UV_CPU}${NC}mV GPU=${GREEN}${UV_GPU}${NC}mV Cache=${GREEN}${UV_CACHE}${NC}mV"
    echo -e "  TDP:       PL1=${GREEN}${PL1_CURRENT}${NC}W PL2=${GREEN}${PL2_CURRENT}${NC}W (${PL1_TIME}s)"
    echo -e "  PROCHOT:   ${GREEN}${PROCHOT_TEMP}°C${NC}"
    echo -e "  Freq:      ${GREEN}${MIN_FREQ}${NC}-${GREEN}${MAX_FREQ}${NC} MHz (HW max: ${CPUINFO_MAX}MHz)"
    echo ""
}

do_apply() {
    echo -e "${CYAN}Aplicando configuración guardada...${NC}"

    detect_cpu
    detect_cores
    detect_tjmax
    CPUINFO_MAX=$(cat /sys/devices/system/cpu/cpu0/cpufreq/cpuinfo_max_freq 2>/dev/null || echo "0")
    CPUINFO_MAX=$((CPUINFO_MAX / 1000))

    read_current_undervolt
    read_current_power
    read_current_freq

    local errors=0

    if [ -f "$UNDERVOLT_CONF" ]; then
        apply_undervolt || errors=$((errors + 1))
    fi

    if [ -f "$POWER_CONF" ]; then
        apply_power_limits || errors=$((errors + 1))
        apply_prochot || errors=$((errors + 1))
    fi

    if [ -f "$FREQ_CONF" ]; then
        apply_frequency_limits || errors=$((errors + 1))
    fi

    if [ "$errors" -eq 0 ]; then
        echo -e "${GREEN}✓ Configuración aplicada correctamente${NC}"
    else
        echo -e "${YELLOW}⚠ Aplicada con $errors error(es)${NC}"
    fi
}

show_help() {
    echo "nothrottle v${VERSION} — ThrottleStop-like power management for Linux"
    echo ""
    echo "Uso: sudo nothrottle [opción]"
    echo ""
    echo "Sin opciones:  Inicia la interfaz interactiva (TUI)"
    echo ""
    echo "Opciones:"
    echo "  --install     Instalar en el sistema (/usr/local/bin/)"
