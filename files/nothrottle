DESKTOPEOF
}

# ============================================================================
# INICIO DEL PROGRAMA
# ============================================================================

# Parsear argumentos CLI ANTES de requerir root (--help y --version no lo necesitan)
case "${1:-}" in
    --help|-h)
        show_help
        exit 0
        ;;
    --version|-v)
        echo "$VERSION"
        exit 0
        ;;
esac

# A partir de aquí se requiere root
if [ "$EUID" -ne 0 ]; then
    echo -e "${RED}Este programa debe ejecutarse como root${NC}"
    echo "Ejecuta: sudo nothrottle"
    exit 1
fi

# Crear directorios si no existen
mkdir -p "$CONFIG_DIR"

# Despachar comandos CLI
case "${1:-}" in
    --install)
        do_install
        exit 0
        ;;
    --uninstall)
        do_uninstall
        exit 0
        ;;
    --status)
        do_status
        exit 0
        ;;
    --apply)
        do_apply
        exit 0
        ;;
    "")
        # Sin argumentos: modo TUI interactivo (flujo original)
        ;;
    *)
        echo -e "${RED}Opción desconocida: $1${NC}"
        echo "Usa: nothrottle --help"
        exit 1
        ;;
esac

# Verificar dependencias para TUI
if ! command -v intel-undervolt >/dev/null 2>&1; then
    echo -e "${YELLOW}⚠ Advertencia: intel-undervolt no está instalado${NC}"
    echo "  El undervolt no estará disponible"
fi

# Verificar que es CPU Intel (AMD no soportado)
if grep -qi "AuthenticAMD" /proc/cpuinfo; then
    echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
    echo -e "${RED}  ADVERTENCIA: CPU AMD detectada${NC}"
    echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
    echo ""
    echo -e "  Esta herramienta está diseñada para CPUs Intel."
    echo -e "  En AMD:"
    echo -e "    • Undervolt no funciona (usa Curve Optimizer en BIOS)"
    echo -e "    • PROCHOT/MSR son incompatibles"
    echo -e "    • TDP vía RAPL puede funcionar parcialmente"
    echo -e "    • Frecuencias vía cpufreq sí funcionan"
    echo ""
    echo -e "  Para AMD se recomienda: ${CYAN}ryzenadj${NC} o configurar desde BIOS"
    echo ""
    read -p "¿Continuar de todos modos? (s/n) [n]: " amd_confirm
    amd_confirm=${amd_confirm:-n}
    if [ "$amd_confirm" != "s" ] && [ "$amd_confirm" != "S" ]; then
        echo "Saliendo."
        exit 0
    fi
fi

# Detectar hardware
detect_cpu
detect_cores
detect_tjmax

# Inicializar CPUINFO_MAX para que validate_frequency() lo tenga disponible
# read_current_freq() lo actualiza después, pero necesita un valor por defecto
CPUINFO_MAX=$(cat /sys/devices/system/cpu/cpu0/cpufreq/cpuinfo_max_freq 2>/dev/null || echo "0")
CPUINFO_MAX=$((CPUINFO_MAX / 1000))

# Iniciar menú principal
main_menu
