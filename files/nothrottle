        show_header
        show_cpu_info

        echo -e "${BOLD}${YELLOW}═══ TECNOLOGÍAS DE GESTIÓN DE ENERGÍA ═══${NC}"
        echo ""

        # Estado actual con colores
        local ss_c; [ "$SPEEDSTEP_ENABLED" = "true" ] && ss_c="${GREEN}ON" || ss_c="${YELLOW}OFF"
        local sh_c; [ "$SPEEDSHIFT_ENABLED" = "true" ] && sh_c="${GREEN}ON" || sh_c="${YELLOW}OFF"
        local c1_c; [ "$C1E_ENABLED" = "true" ] && c1_c="${GREEN}ON" || c1_c="${YELLOW}OFF"
        local bd_c; [ "$BD_PROCHOT_ENABLED" = "true" ] && bd_c="${GREEN}ON" || bd_c="${RED}OFF"
        local tb_c; [ "$TURBO_ENABLED" = "true" ] && tb_c="${GREEN}ON" || tb_c="${YELLOW}OFF"

        echo -e "  Estado actual:"
        echo -e "    SpeedStep (EIST):    ${ss_c}${NC}  (escalado de frecuencia clásico)"
        echo -e "    Speed Shift (HWP):   ${sh_c}${NC}  (escalado hardware, más rápido)"
        echo -e "    C1E auto-promotion:  ${c1_c}${NC}  (C-state profundo en idle)"
        echo -e "    BD-PROCHOT:          ${bd_c}${NC}  (otros componentes pueden throttlear CPU)"
        echo -e "    Turbo Boost:         ${tb_c}${NC}  (frecuencias por encima de base)"
        echo -e "    EPP:                 ${CYAN}${EPP_CURRENT}${NC}"
        echo -e "    Driver:              ${CYAN}${PSTATE_DRIVER}${NC} (${PSTATE_STATUS})"
        if [ "$HWP_ENABLED" = "true" ] && [ "$HWP_HIGHEST" -gt 0 ]; then
            echo -e "    HWP Ratios:          High=$((HWP_HIGHEST * 100))MHz Guar=$((HWP_GUARANTEED * 100))MHz Eff=$((HWP_EFFICIENT * 100))MHz Low=$((HWP_LOWEST * 100))MHz"
        fi
        echo ""

        echo -e "  ${BOLD}Límites alcanzados:${NC}"
        echo -e "    Activos:   $THROTTLE_REASONS"
        echo -e "    Histórico: ${DIM}${THROTTLE_LOG:-Ninguno}${NC}"
        echo ""

        echo -e "  Opciones:"
        echo -e "    ${GREEN}1)${NC} Toggle BD-PROCHOT (${bd_c}${NC})"
        echo -e "    ${GREEN}2)${NC} Toggle C1E (${c1_c}${NC})"
        echo -e "    ${GREEN}3)${NC} Toggle Turbo Boost (${tb_c}${NC})"
        echo -e "    ${GREEN}4)${NC} Cambiar EPP (Energy Performance Preference)"
        echo -e "    ${CYAN}5)${NC} Reset log de throttle (limpiar MSR 0x64F)"
        echo -e "    ${BLUE}b)${NC} Volver"
        echo ""
        echo -e "${DIM}  SpeedStep/Speed Shift se controlan desde BIOS o kernel cmdline${NC}"
        echo -e "${DIM}  (intel_pstate=disable / intel_pstate=passive / intel_pstate=no_hwp)${NC}"
        echo ""
        read -p "Selecciona opción: " opt

        case $opt in
            1)
                if [ "$BD_PROCHOT_ENABLED" = "true" ]; then
                    echo ""
                    echo -e "${YELLOW}⚠ Deshabilitar BD-PROCHOT permite que el CPU ignore señales${NC}"
                    echo -e "${YELLOW}  de sobrecalentamiento de otros componentes (GPU, VRM).${NC}"
                    echo -e "${YELLOW}  Puede aumentar temperaturas y causar daño en portátiles.${NC}"
                    read -p "  ¿Deshabilitar BD-PROCHOT? (s/n): " confirm
                    if [ "$confirm" = "s" ] || [ "$confirm" = "S" ]; then
                        toggle_bd_prochot "disable"
                    fi
                else
                    toggle_bd_prochot "enable"
                fi
                read -p "Presiona Enter..."
                ;;
            2)
                if [ "$C1E_ENABLED" = "true" ]; then
                    toggle_c1e "disable"
                    echo -e "${CYAN}  Deshabilitado: el CPU no entrará en C1E automáticamente.${NC}"
                    echo -e "${CYAN}  Reduce latencia pero aumenta consumo idle.${NC}"
                else
                    toggle_c1e "enable"
                    echo -e "${CYAN}  Habilitado: el CPU entrará en C1E en idle (ahorra energía).${NC}"
                fi
                read -p "Presiona Enter..."
                ;;
            3)
                if [ "$TURBO_ENABLED" = "true" ]; then
                    toggle_turbo "disable"
                    echo -e "${CYAN}  Turbo deshabilitado: frecuencia limitada a base clock.${NC}"
                else
                    toggle_turbo "enable"
                    echo -e "${CYAN}  Turbo habilitado: frecuencias boost disponibles.${NC}"
                fi
                read -p "Presiona Enter..."
                ;;
            4)
                echo ""
                echo -e "${BOLD}  Energy Performance Preference:${NC}"
                if [ -n "$EPP_AVAILABLE" ]; then
                    echo -e "  Disponibles: ${CYAN}${EPP_AVAILABLE}${NC}"
                fi
                echo ""
                echo "  1) performance          (máximo rendimiento, más consumo)"
                echo "  2) balance_performance   (equilibrio hacia rendimiento)"
                echo "  3) balance_power         (equilibrio hacia ahorro)"
                echo "  4) power                 (máximo ahorro, menos rendimiento)"
                echo ""
                read -p "  Selecciona (1-4): " epp_opt
                case $epp_opt in
                    1) set_epp "performance" ;;
                    2) set_epp "balance_performance" ;;
                    3) set_epp "balance_power" ;;
                    4) set_epp "power" ;;
                esac
                read -p "Presiona Enter..."
                ;;
            5)
                # Reset log bits en MSR 0x64F
                if command -v wrmsr >/dev/null 2>&1 && [ -c /dev/cpu/0/msr ]; then
                    for core in $(seq 0 $((CPU_CORES - 1))); do
                        wrmsr -p "$core" 0x64F 0x0 2>/dev/null
                    done
                    echo -e "${GREEN}✓ Log de throttle limpiado${NC}"
                else
                    echo -e "${RED}✗ Requiere msr-tools${NC}"
                fi
                read -p "Presiona Enter..."
                ;;
            b|B) return ;;
        esac
    done
}

