menu_monitoring() {
    local refresh_interval=2
    local prev_energy=0
    local prev_time=0
    local current_power_w="N/A"
    
    # Arrays para cálculo de uso de CPU entre muestras
    declare -A prev_idle
    declare -A prev_total
    declare -A core_usage_pct
    
    # Tomar primera muestra de /proc/stat para tener un delta en el primer ciclo
    while IFS= read -r line; do
        if [[ "$line" =~ ^cpu([0-9]+) ]]; then
            local cnum="${BASH_REMATCH[1]}"
            local fields
            read -ra fields <<< "$line"
            local idle_val=${fields[4]}
            local iowait_val=${fields[5]:-0}
            local t=0
            for ((f=1; f<${#fields[@]}; f++)); do t=$((t + fields[f])); done
            prev_idle[$cnum]=$((idle_val + iowait_val))
            prev_total[$cnum]=$t
            core_usage_pct[$cnum]=0
        fi
    done < /proc/stat
    sleep 0.3
    
    while true; do
        # ── Calcular uso por core desde /proc/stat ──
        while IFS= read -r line; do
            if [[ "$line" =~ ^cpu([0-9]+) ]]; then
                local cnum="${BASH_REMATCH[1]}"
                local fields
                read -ra fields <<< "$line"
                local idle_val=${fields[4]}
                local iowait_val=${fields[5]:-0}
                local t=0
                for ((f=1; f<${#fields[@]}; f++)); do t=$((t + fields[f])); done
                local curr_idle=$((idle_val + iowait_val))
                local dt=$((t - ${prev_total[$cnum]:-0}))
                local di=$((curr_idle - ${prev_idle[$cnum]:-0}))
                if [ "$dt" -gt 0 ]; then
                    core_usage_pct[$cnum]=$(( (dt - di) * 100 / dt ))
                else
                    core_usage_pct[$cnum]=0
                fi
                prev_idle[$cnum]=$curr_idle
                prev_total[$cnum]=$t
            fi
        done < /proc/stat
        
        clear
        echo -e "${BOLD}${CYAN}╔════════════════════════════════════════════════════════════════════════════════╗${NC}"
        printf "${BOLD}${CYAN}║              MONITOREO EN TIEMPO REAL  (refresco: %-2ss)                      ║${NC}\n" "$refresh_interval"
        echo -e "${BOLD}${CYAN}╚════════════════════════════════════════════════════════════════════════════════╝${NC}"
        echo ""
        
        # ── Calcular potencia real (W) entre muestras ──
        if [ -f /sys/class/powercap/intel-rapl/intel-rapl:0/energy_uj ]; then
            local curr_energy curr_time
            curr_energy=$(cat /sys/class/powercap/intel-rapl/intel-rapl:0/energy_uj 2>/dev/null || echo "0")
            curr_time=$(date +%s%N)
            if [ "$prev_energy" -gt 0 ] && [ "$prev_time" -gt 0 ]; then
                local delta_e=$((curr_energy - prev_energy))
                local delta_t=$((curr_time - prev_time))
                # Si el contador se desbordó, saltar este ciclo
                if [ "$delta_e" -gt 0 ] && [ "$delta_t" -gt 0 ]; then
                    # delta_e en µJ, delta_t en ns → W = (delta_e * 1000) / delta_t
                    current_power_w=$(awk "BEGIN { printf \"%.1f\", ($delta_e / 1000000.0) / ($delta_t / 1000000000.0) }")
                fi
            fi
            prev_energy=$curr_energy
            prev_time=$curr_time
        fi
        
        # ── Detectar estado de throttling ──
        local throttle_status=""
        local is_throttling=false
        
        # Método 1: thermal throttle count del kernel
        local total_throttle_count=0
        for tc in /sys/devices/system/cpu/cpu*/thermal_throttle/core_throttle_count; do
            if [ -f "$tc" ]; then
                local count
                count=$(cat "$tc" 2>/dev/null || echo "0")
                total_throttle_count=$((total_throttle_count + count))
            fi
        done
        
        # Método 2: package throttle count
        local pkg_throttle=0
        if [ -f /sys/devices/system/cpu/cpu0/thermal_throttle/package_throttle_count ]; then
            pkg_throttle=$(cat /sys/devices/system/cpu/cpu0/thermal_throttle/package_throttle_count 2>/dev/null || echo "0")
        fi
        
        # Método 3: Verificar si algún core está corriendo muy por debajo del máximo con carga
        local any_core_limited=false
        
        # Método 4: Temperatura Package (indicador de throttling térmico inminente)
        local pkg_temp="N/A"
        if command -v sensors >/dev/null 2>&1; then
            pkg_temp=$(sensors 2>/dev/null | grep -i "Package id 0" | grep -oP '\+\K[0-9]+' | head -1)
            [ -z "$pkg_temp" ] && pkg_temp="N/A"
        fi
        
        # Método 5: intel_rapl throttled bits
        local rapl_throttled=false
        if [ -f /sys/class/powercap/intel-rapl/intel-rapl:0/constraint_0_power_limit_uw ] && \
           [ -f /sys/class/powercap/intel-rapl/intel-rapl:0/enabled ]; then
            local rapl_enabled
            rapl_enabled=$(cat /sys/class/powercap/intel-rapl/intel-rapl:0/enabled 2>/dev/null || echo "0")
            if [ "$rapl_enabled" = "1" ]; then
                # Si la potencia actual supera PL1, probablemente hay throttling por potencia
                if [ "$current_power_w" != "N/A" ] && [ "$PL1_CURRENT" -gt 0 ]; then
                    local power_int
                    power_int=$(printf "%.0f" "$current_power_w" 2>/dev/null || echo "0")
                    if [ "$power_int" -ge "$PL1_CURRENT" ]; then
                        rapl_throttled=true
                    fi
                fi
            fi
        fi
        
        # Determinar estado global de throttling
        if [ "$pkg_temp" != "N/A" ] && [ "$pkg_temp" -ge "$PROCHOT_TEMP" ]; then
            throttle_status="${RED}${BOLD}⚠ THROTTLING TÉRMICO ACTIVO${NC} (${pkg_temp}°C >= ${PROCHOT_TEMP}°C)"
            is_throttling=true
        elif [ "$rapl_throttled" = true ]; then
            throttle_status="${YELLOW}${BOLD}⚠ THROTTLING POR POTENCIA${NC} (${current_power_w}W >= PL1: ${PL1_CURRENT}W)"
            is_throttling=true
        elif [ "$pkg_temp" != "N/A" ] && [ "$pkg_temp" -ge $((PROCHOT_TEMP - 5)) ]; then
            throttle_status="${YELLOW}⚡ CERCA DEL LÍMITE TÉRMICO${NC} (${pkg_temp}°C → throttling a ${PROCHOT_TEMP}°C)"
        else
            throttle_status="${GREEN}✓ Sin throttling${NC}"
        fi
        
        # ── Panel de estado ──
        echo -e "${BOLD}Estado:${NC} $throttle_status"
        echo ""
        
        # Resumen rápido
        local governor="N/A"
        if [ -f /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor ]; then
            governor=$(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor 2>/dev/null || echo "N/A")
        fi
        
        echo -e "  Paquete: ${BOLD}${pkg_temp}°C${NC} / ${PROCHOT_TEMP}°C    Potencia: ${BOLD}${current_power_w}W${NC} / PL1: ${PL1_CURRENT}W    Governor: ${BOLD}${governor}${NC}"
        echo -e "  Throttle events: core=${total_throttle_count} pkg=${pkg_throttle}    HW Max: ${CPUINFO_MAX} MHz"

        # MSR Throttle Reasons (lectura rápida, sin reinicializar todo)
        if command -v rdmsr >/dev/null 2>&1 && [ -c /dev/cpu/0/msr ]; then
            local plr
            plr=$(rdmsr -p 0 0x64F 2>/dev/null)
            if [ -n "$plr" ]; then
                local plr_val=$((16#$plr))
                local active_flags=""
                local log_flags=""
                # Active bits
                [ $((plr_val & 0x1)) -ne 0 ] && active_flags="${active_flags}${RED}PROCHOT${NC} "
                [ $((plr_val & 0x2)) -ne 0 ] && active_flags="${active_flags}${RED}THERMAL${NC} "
                [ $((plr_val & 0x40)) -ne 0 ] && active_flags="${active_flags}${RED}VR-THERM${NC} "
                [ $((plr_val & 0x100)) -ne 0 ] && active_flags="${active_flags}${RED}EDP${NC} "
                [ $((plr_val & 0x400)) -ne 0 ] && active_flags="${active_flags}${RED}PL1${NC} "
                [ $((plr_val & 0x800)) -ne 0 ] && active_flags="${active_flags}${RED}PL2${NC} "
                [ $((plr_val & 0x4000)) -ne 0 ] && active_flags="${active_flags}${YELLOW}TURBO${NC} "
                [ -z "$active_flags" ] && active_flags="${GREEN}--${NC}"
                # Log bits
                [ $((plr_val & 0x10000)) -ne 0 ] && log_flags="${log_flags}PROCHOT "
                [ $((plr_val & 0x20000)) -ne 0 ] && log_flags="${log_flags}THERMAL "
                [ $((plr_val & 0x4000000)) -ne 0 ] && log_flags="${log_flags}PL1 "
                [ $((plr_val & 0x8000000)) -ne 0 ] && log_flags="${log_flags}PL2 "
                [ $((plr_val & 0x10000000)) -ne 0 ] && log_flags="${log_flags}TURBO "
                [ -z "$log_flags" ] && log_flags="--"
                echo -e "  MSR Limits: active=[${active_flags}]  log=[${DIM}${log_flags}${NC}]"
            fi
        fi
        echo ""
        
        # ── Tabla de núcleos ──
        # Cabecera de tabla
        local col_core=8
        local col_type=6
        local col_freq=12
        local col_min=10
        local col_max=10
        local col_temp=8
        local col_usage=8
        local col_throttle=12
        
        echo -e "${BOLD}${CYAN}┌────────┬──────┬────────────┬──────────┬──────────┬────────┬────────┬────────────┐${NC}"
        echo -e "${BOLD}${CYAN}│ Núcleo │ Tipo │  Frec.MHz  │  Mín.MHz │  Máx.MHz │ Temp°C │  Uso%  │  Throttle  │${NC}"
        echo -e "${BOLD}${CYAN}├────────┼──────┼────────────┼──────────┼──────────┼────────┼────────┼────────────┤${NC}"
        
        local core_idx=0
        for cpu_dir in /sys/devices/system/cpu/cpu[0-9]*/; do
            local cpu_num
            cpu_num=$(basename "$cpu_dir" | tr -cd '0-9')
            
            # Frecuencia actual
            local cur_freq=0
            if [ -f "${cpu_dir}cpufreq/scaling_cur_freq" ]; then
                cur_freq=$(cat "${cpu_dir}cpufreq/scaling_cur_freq" 2>/dev/null || echo "0")
                cur_freq=$((cur_freq / 1000))
            fi
            
            # Frecuencia mínima configurada
            local min_freq=0
            if [ -f "${cpu_dir}cpufreq/scaling_min_freq" ]; then
                min_freq=$(cat "${cpu_dir}cpufreq/scaling_min_freq" 2>/dev/null || echo "0")
                min_freq=$((min_freq / 1000))
            fi
            
            # Frecuencia máxima configurada
            local max_freq=0
            if [ -f "${cpu_dir}cpufreq/scaling_max_freq" ]; then
                max_freq=$(cat "${cpu_dir}cpufreq/scaling_max_freq" 2>/dev/null || echo "0")
                max_freq=$((max_freq / 1000))
            fi
            
            # Tipo de core
            local core_type="──"
            if [ "$HAS_HYBRID" = true ] && [ "$E_CORES" -gt 0 ]; then
                if echo " $P_CORE_LIST " | grep -q " ${cpu_num} "; then
                    core_type=" P"
                elif echo " $E_CORE_LIST " | grep -q " ${cpu_num} "; then
                    core_type=" E"
                else
                    core_type=" ?"
                fi
            fi
            
            # Temperatura por core (si está disponible)
            local core_temp="─"
            if command -v sensors >/dev/null 2>&1; then
                core_temp=$(sensors 2>/dev/null | grep -i "Core ${cpu_num}:" | grep -oP '\+\K[0-9]+' | head -1)
                [ -z "$core_temp" ] && core_temp="─"
            fi
            
            # Uso del core desde el cálculo delta de /proc/stat
            local usage="${core_usage_pct[$cpu_num]:-0}"
            
            # Throttle por core
            local core_throttle_count="0"
            if [ -f "${cpu_dir}thermal_throttle/core_throttle_count" ]; then
                core_throttle_count=$(cat "${cpu_dir}thermal_throttle/core_throttle_count" 2>/dev/null || echo "0")
            fi
            
            # Colorear frecuencia según % del máximo HW
            local freq_color="${GREEN}"
            if [ "$CPUINFO_MAX" -gt 0 ]; then
                local freq_pct=$((cur_freq * 100 / CPUINFO_MAX))
                if [ "$freq_pct" -lt 30 ]; then
                    freq_color="${BLUE}"
                elif [ "$freq_pct" -lt 60 ]; then
                    freq_color="${GREEN}"
                elif [ "$freq_pct" -lt 90 ]; then
                    freq_color="${YELLOW}"
                else
                    freq_color="${RED}"
                fi
            fi
            
            # Colorear temperatura
            local temp_color="${GREEN}"
            if [ "$core_temp" != "─" ]; then
                if [ "$core_temp" -ge "$PROCHOT_TEMP" ]; then
                    temp_color="${RED}"
                elif [ "$core_temp" -ge $((PROCHOT_TEMP - 10)) ]; then
                    temp_color="${YELLOW}"
                fi
            fi
            
            # Colorear uso
            local usage_color="${GREEN}"
            if [ "$usage" -ge 90 ]; then
                usage_color="${RED}"
            elif [ "$usage" -ge 60 ]; then
                usage_color="${YELLOW}"
            fi
            
            # Colorear throttle
            local thr_color="${GREEN}"
            if [ "$core_throttle_count" -gt 100 ]; then
                thr_color="${RED}"
            elif [ "$core_throttle_count" -gt 0 ]; then
                thr_color="${YELLOW}"
            fi
            
            # Barra visual de frecuencia (8 chars)
            local bar=""
            if [ "$CPUINFO_MAX" -gt 0 ]; then
                local bar_pct=$((cur_freq * 8 / CPUINFO_MAX))
                [ "$bar_pct" -gt 8 ] && bar_pct=8
                local bar_filled=""
                local bar_empty=""
                for ((b=0; b<bar_pct; b++)); do bar_filled+="█"; done
                for ((b=bar_pct; b<8; b++)); do bar_empty+="░"; done
                bar="${freq_color}${bar_filled}${NC}${bar_empty}"
            fi
            
            printf "${CYAN}│${NC} %4s   ${CYAN}│${NC}  %b  ${CYAN}│${NC} %b %5d ${CYAN}│${NC}   %5d  ${CYAN}│${NC}   %5d  ${CYAN}│${NC}  %b%-4s ${CYAN}│${NC}  %b%3d%%  ${CYAN}│${NC}  %b%-8s ${CYAN}│${NC}\n" \
                "cpu${cpu_num}" \
                "${BOLD}${core_type}${NC}" \
                "${bar}" "$cur_freq" \
                "$min_freq" \
                "$max_freq" \
                "${temp_color}" "${core_temp}" \
                "${usage_color}" "${usage}" \
                "${thr_color}" "${core_throttle_count}${NC}"
            
            core_idx=$((core_idx + 1))
        done
        
        echo -e "${BOLD}${CYAN}└────────┴──────┴────────────┴──────────┴──────────┴────────┴────────┴────────────┘${NC}"
        echo ""
        
        # ── Panel de throttling detallado ──
        if [ "$is_throttling" = true ]; then
            echo -e "${BOLD}${RED}┌─ DETALLE DE THROTTLING ─────────────────────────────────────────────────────┐${NC}"
            if [ "$pkg_temp" != "N/A" ] && [ "$pkg_temp" -ge "$PROCHOT_TEMP" ]; then
                echo -e "${RED}│${NC}  ${RED}TÉRMICO:${NC} Temperatura del paquete (${pkg_temp}°C) alcanzó el límite (${PROCHOT_TEMP}°C)"
                echo -e "${RED}│${NC}  ${YELLOW}→ El CPU está reduciendo frecuencia para bajar temperatura${NC}"
                echo -e "${RED}│${NC}  ${CYAN}Solución: Reducir carga, mejorar ventilación, o subir límite térmico${NC}"
            fi
            if [ "$rapl_throttled" = true ]; then
                echo -e "${RED}│${NC}  ${RED}POTENCIA:${NC} Consumo (${current_power_w}W) alcanzó PL1 (${PL1_CURRENT}W)"
                echo -e "${RED}│${NC}  ${YELLOW}→ El CPU está limitando frecuencia para no exceder el TDP${NC}"
                echo -e "${RED}│${NC}  ${CYAN}Solución: Aumentar PL1/PL2 o reducir carga de trabajo${NC}"
            fi
            echo -e "${BOLD}${RED}└─────────────────────────────────────────────────────────────────────────────┘${NC}"
            echo ""
        fi
        
        # ── Controles ──
        echo -e "  ${BLUE}+/-${NC} Cambiar intervalo de refresco (actual: ${BOLD}${refresh_interval}s${NC})"
        echo -e "  ${BLUE}r${NC}   Refrescar ahora"
        echo -e "  ${BLUE}b${NC}   Volver al menú"
        echo ""
        
        read -t "$refresh_interval" -n1 -p "" opt 2>/dev/null
        
        case "$opt" in
            b|B) return ;;
            +|=)
                if [ "$refresh_interval" -lt 30 ]; then
                    refresh_interval=$((refresh_interval + 1))
                fi
                ;;
            -)
                if [ "$refresh_interval" -gt 1 ]; then
                    refresh_interval=$((refresh_interval - 1))
                fi
                ;;
            s)
                # Menú de selección de intervalo
                echo ""
                echo ""
                echo -e "  Intervalo de refresco (segundos):"
                echo -e "    1) ${GREEN}1s${NC}  - Tiempo real"
                echo -e "    2) ${GREEN}2s${NC}  - Recomendado"
                echo -e "    3) ${GREEN}5s${NC}  - Moderado"
                echo -e "    4) ${GREEN}10s${NC} - Bajo consumo"
                echo ""
                read -p "  Selecciona (1-4): " interval_opt
                case "$interval_opt" in
                    1) refresh_interval=1 ;;
                    2) refresh_interval=2 ;;
                    3) refresh_interval=5 ;;
                    4) refresh_interval=10 ;;
                esac
                ;;
            *) continue ;;
        esac
    done
}

menu_technologies() {
    while true; do
