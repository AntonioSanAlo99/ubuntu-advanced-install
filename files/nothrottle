    echo -e "  1. Arrancar en modo recovery"
    echo -e "  2. Deshabilitar el servicio: systemctl disable nothrottle"
    echo ""
    echo -e "${BOLD}Para confirmar, escribe exactamente:${NC} ${GREEN}GUARDAR PERMANENTE${NC}"
    echo -e "${BOLD}Para cancelar, escribe cualquier otra cosa${NC}"
    echo ""
    read -p "Confirmación: " confirmation
    
    if [ "$confirmation" = "GUARDAR PERMANENTE" ]; then
        # Guardar configuración de undervolt
        cat > "$UNDERVOLT_CONF" << EOF
# NoThrottle - Undervolt Config
UV_CPU=$UV_CPU
UV_GPU=$UV_GPU
UV_CACHE=$UV_CACHE
UV_SA=$UV_SA
UV_IO=$UV_IO
EOF
        
        # Guardar configuración de power
        cat > "$POWER_CONF" << EOF
# NoThrottle - Power Config
PL1_CURRENT=$PL1_CURRENT
PL2_CURRENT=$PL2_CURRENT
PL1_TIME=$PL1_TIME
PROCHOT_TEMP=$PROCHOT_TEMP
EOF
        
        # Guardar configuración de frecuencias
        cat > "$FREQ_CONF" << EOF
# NoThrottle - Frequency Config
TARGET_MAX_FREQ=$TARGET_MAX_FREQ
TARGET_MIN_FREQ=$TARGET_MIN_FREQ
P_CORE_MAX=$P_CORE_MAX
E_CORE_MAX=$E_CORE_MAX
EOF
        
        # Guardar configuración de intel-undervolt
        if command -v intel-undervolt >/dev/null 2>&1; then
            cat > /etc/intel-undervolt.conf << EOF
# Intel Undervolt Configuration - Auto-generated by NoThrottle
undervolt 0 'CPU' $UV_CPU
undervolt 1 'GPU' $UV_GPU
undervolt 2 'CPU Cache' $UV_CACHE
undervolt 3 'System Agent' $UV_SA
undervolt 4 'Analog I/O' $UV_IO
EOF
        fi
        
        # Crear script de inicio
        create_startup_service
        
        echo ""
        echo -e "${GREEN}✓✓✓ CONFIGURACIÓN GUARDADA PERMANENTEMENTE ✓✓✓${NC}"
        echo ""
        echo -e "  📁 Archivos de configuración:"
        echo -e "     $UNDERVOLT_CONF"
        echo -e "     $POWER_CONF"
        echo -e "     $FREQ_CONF"
        echo ""
        echo -e "  🔄 Servicio de arranque: HABILITADO"
        echo -e "     systemctl status nothrottle"
        echo ""
        echo -e "  ✅ Esta configuración se aplicará en cada arranque"
        echo ""
        
        UNSAVED_CHANGES=false
        return 0
    else
        echo ""
        echo -e "${RED}✗ Guardado cancelado${NC}"
        echo -e "  Los cambios actuales siguen activos pero NO son persistentes"
        echo ""
        return 1
    fi
}

create_startup_service() {
    # Crear script de aplicación
    cat > /usr/local/bin/nothrottle-apply << 'APPLYSCRIPT'
#!/bin/bash
# NoThrottle - Apply on boot

CONFIG_DIR="/etc/nothrottle"

# Función de parseo seguro (sin source)
safe_read() {
    local file=$1 key=$2
    grep -E "^${key}=" "$file" 2>/dev/null | head -1 | cut -d= -f2 | tr -cd '0-9-'
}

# Inicializar variables vacías para evitar errores con -n checks
PL1_CURRENT=""
PL2_CURRENT=""
PL1_TIME=""
PROCHOT_TEMP=""
TARGET_MAX_FREQ=""
TARGET_MIN_FREQ=""
P_CORE_MAX=""
E_CORE_MAX=""

# Leer configuraciones de forma segura
if [ -f "$CONFIG_DIR/power.conf" ]; then
    PL1_CURRENT=$(safe_read "$CONFIG_DIR/power.conf" "PL1_CURRENT")
    PL2_CURRENT=$(safe_read "$CONFIG_DIR/power.conf" "PL2_CURRENT")
    PL1_TIME=$(safe_read "$CONFIG_DIR/power.conf" "PL1_TIME")
    PROCHOT_TEMP=$(safe_read "$CONFIG_DIR/power.conf" "PROCHOT_TEMP")
fi

if [ -f "$CONFIG_DIR/frequency.conf" ]; then
    TARGET_MAX_FREQ=$(safe_read "$CONFIG_DIR/frequency.conf" "TARGET_MAX_FREQ")
    TARGET_MIN_FREQ=$(safe_read "$CONFIG_DIR/frequency.conf" "TARGET_MIN_FREQ")
    P_CORE_MAX=$(safe_read "$CONFIG_DIR/frequency.conf" "P_CORE_MAX")
    E_CORE_MAX=$(safe_read "$CONFIG_DIR/frequency.conf" "E_CORE_MAX")
fi

# Aplicar undervolt
if command -v intel-undervolt >/dev/null 2>&1; then
    intel-undervolt apply 2>/dev/null
fi

# Aplicar power limits
if [ -d /sys/class/powercap/intel-rapl/intel-rapl:0/ ]; then
    [ -n "$PL1_CURRENT" ] && echo $((PL1_CURRENT * 1000000)) > /sys/class/powercap/intel-rapl/intel-rapl:0/constraint_0_power_limit_uw 2>/dev/null
    [ -n "$PL2_CURRENT" ] && echo $((PL2_CURRENT * 1000000)) > /sys/class/powercap/intel-rapl/intel-rapl:0/constraint_1_power_limit_uw 2>/dev/null
    [ -n "$PL1_TIME" ] && echo $((PL1_TIME * 1000000)) > /sys/class/powercap/intel-rapl/intel-rapl:0/constraint_0_time_window_us 2>/dev/null
fi

# Aplicar PROCHOT (temperatura de throttling) via MSR
if [ -n "$PROCHOT_TEMP" ] && command -v rdmsr >/dev/null 2>&1 && command -v wrmsr >/dev/null 2>&1; then
    # Cargar módulo msr
    [ ! -c /dev/cpu/0/msr ] && modprobe msr 2>/dev/null
    if [ -c /dev/cpu/0/msr ]; then
        # Leer Tjmax desde MSR 0x1A2 bits 23:16
        TJMAX_HEX=$(rdmsr -f 23:16 0x1A2 2>/dev/null)
        if [ -n "$TJMAX_HEX" ]; then
            TJMAX=$((16#$TJMAX_HEX))
            OFFSET=$((TJMAX - PROCHOT_TEMP))
            [ "$OFFSET" -lt 0 ] && OFFSET=0
            [ "$OFFSET" -gt 63 ] && OFFSET=63
            FULL_MSR=$(rdmsr 0x1A2 2>/dev/null)
            if [ -n "$FULL_MSR" ]; then
                FULL_VAL=$((16#$FULL_MSR))
                FULL_VAL=$(( (FULL_VAL & ~(0x3F << 24)) | (OFFSET << 24) ))
                NEW_HEX=$(printf "0x%x" $FULL_VAL)
                wrmsr -a 0x1A2 "$NEW_HEX" 2>/dev/null
            fi
        fi
    fi
fi

# Aplicar frecuencias globales
if [ -n "$TARGET_MAX_FREQ" ]; then
    for cpu in /sys/devices/system/cpu/cpu*/cpufreq/scaling_max_freq; do
        [ -f "$cpu" ] && echo $((TARGET_MAX_FREQ * 1000)) > "$cpu" 2>/dev/null
    done
fi

if [ -n "$TARGET_MIN_FREQ" ]; then
    for cpu in /sys/devices/system/cpu/cpu*/cpufreq/scaling_min_freq; do
        [ -f "$cpu" ] && echo $((TARGET_MIN_FREQ * 1000)) > "$cpu" 2>/dev/null
    done
fi

# Aplicar frecuencias P/E-core si están configuradas y hay arquitectura híbrida
if [ -n "$P_CORE_MAX" ] || [ -n "$E_CORE_MAX" ]; then
    # Detectar P/E cores via cpu_capacity
    if [ -f /sys/devices/system/cpu/cpu0/cpu_capacity ]; then
        for cpu_dir in /sys/devices/system/cpu/cpu[0-9]*/; do
            cpu_num=$(basename "$cpu_dir" | tr -cd '0-9')
            cap_file="${cpu_dir}cpu_capacity"
            freq_file="${cpu_dir}cpufreq/scaling_max_freq"
            if [ -f "$cap_file" ] && [ -f "$freq_file" ]; then
                cap=$(cat "$cap_file" 2>/dev/null || echo "0")
                if [ "$cap" -ge 1024 ] && [ -n "$P_CORE_MAX" ]; then
                    echo $((P_CORE_MAX * 1000)) > "$freq_file" 2>/dev/null
                elif [ "$cap" -lt 1024 ] && [ -n "$E_CORE_MAX" ]; then
                    echo $((E_CORE_MAX * 1000)) > "$freq_file" 2>/dev/null
                fi
            fi
        done
    fi
fi

logger "NoThrottle: Configuration applied"
APPLYSCRIPT
    
    chmod +x /usr/local/bin/nothrottle-apply
    
    # Crear servicio systemd
    cat > "$STARTUP_SCRIPT" << 'SERVICEEOF'
[Unit]
Description=NoThrottle - Apply settings on boot
After=sysinit.target
ConditionPathIsDirectory=/etc/nothrottle

[Service]
Type=oneshot
ExecStart=/usr/local/bin/nothrottle-apply
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
SERVICEEOF
    
    # Habilitar servicio
    systemctl daemon-reload
    systemctl enable nothrottle 2>/dev/null
}

check_unsaved_changes() {
    if [ "$UNSAVED_CHANGES" = true ]; then
        echo ""
        echo -e "${BOLD}${RED}════════════════════════════════════════════════════════════════${NC}"
        echo -e "${BOLD}${RED}              ⚠️  CAMBIOS NO GUARDADOS ⚠️${NC}"
        echo -e "${BOLD}${RED}════════════════════════════════════════════════════════════════${NC}"
        echo ""
        echo -e "${YELLOW}Has realizado cambios que están ACTIVOS AHORA pero NO persistirán${NC}"
        echo -e "${YELLOW}después de reiniciar.${NC}"
        echo ""
        echo -e "Opciones:"
        echo -e "  ${GREEN}1)${NC} Guardar configuración (permanente al reiniciar)"
        echo -e "  ${YELLOW}2)${NC} Descartar cambios y salir"
        echo -e "  ${BLUE}3)${NC} Volver al menú principal"
        echo ""
        read -p "Selecciona opción (1-3): " choice
        
        case $choice in
            1)
                save_persistent_config
                if [ $? -eq 0 ]; then
                    return 0
                else
                    return 1
                fi
                ;;
            2)
                echo ""
                echo -e "${YELLOW}Cambios descartados. Los valores volverán al arrancar.${NC}"
                return 0
                ;;
            3)
                return 1
                ;;
            *)
                return 1
                ;;
        esac
    fi
    return 0
}

