    echo "Ubicaciones:"
    echo "  /usr/local/bin/nothrottle    Binario principal"
    echo "  /usr/local/bin/nothrottle-apply      Aplicador ligero (usado en boot)"
    echo "  /etc/nothrottle/             Configuración persistente"
    echo "  /etc/systemd/system/nothrottle.service"
    echo ""
