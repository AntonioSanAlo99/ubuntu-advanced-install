    echo -e "${BOLD}${CYAN}════════════════════════════════════════════════════════════════${NC}"
    echo ""
    echo -e "${YELLOW}Estos límites están basados en ThrottleStop y especificaciones Intel${NC}"
    echo -e "${YELLOW}para proteger tu hardware de configuraciones peligrosas.${NC}"
    echo ""
    read -p "Presiona Enter para continuar..."
}

# Archivos de configuración
CONFIG_DIR="/etc/nothrottle"
UNDERVOLT_CONF="$CONFIG_DIR/undervolt.conf"
POWER_CONF="$CONFIG_DIR/power.conf"
FREQ_CONF="$CONFIG_DIR/frequency.conf"
STARTUP_SCRIPT="/etc/systemd/system/nothrottle.service"

# Estado de cambios sin guardar
UNSAVED_CHANGES=false

# Crear directorios si no existen (para funciones que lo necesitan antes del CLI)
# La creación real ocurre en el bloque de inicio del programa

# ============================================================================
# FUNCIONES DE DETECCIÓN DE HARDWARE
# ============================================================================

detect_cpu() {
    CPU_MODEL=$(grep "model name" /proc/cpuinfo | head -1 | cut -d: -f2 | xargs)
    CPU_CORES=$(nproc)
    
    # Detectar generación Intel
    if echo "$CPU_MODEL" | grep -qi "Core Ultra\|Arrow Lake\|Lunar Lake\|Meteor Lake"; then
        # Core Ultra = 1st gen Core Ultra (Meteor Lake) o 2nd gen (Arrow/Lunar Lake)
        if echo "$CPU_MODEL" | grep -qi "Arrow Lake\|2[0-9][0-9]V\|2[0-9][0-9]H\|2[0-9][0-9]U"; then
            CPU_GEN="Core Ultra 200 (Arrow Lake)"
        elif echo "$CPU_MODEL" | grep -qi "Lunar Lake"; then
            CPU_GEN="Core Ultra 200 (Lunar Lake)"
        else
            CPU_GEN="Core Ultra (Meteor Lake)"
        fi
        HAS_HYBRID=true
    elif echo "$CPU_MODEL" | grep -qi "15th Gen"; then
        CPU_GEN="15th Gen (Arrow Lake)"
        HAS_HYBRID=true
    elif echo "$CPU_MODEL" | grep -qi "14th Gen"; then
        CPU_GEN="14th Gen (Raptor Lake Refresh)"
        HAS_HYBRID=true
    elif echo "$CPU_MODEL" | grep -qi "13th Gen\|Raptor Lake"; then
        CPU_GEN="13th Gen (Raptor Lake)"
        HAS_HYBRID=true
    elif echo "$CPU_MODEL" | grep -qi "12th Gen\|Alder Lake"; then
        CPU_GEN="12th Gen (Alder Lake)"
        HAS_HYBRID=true
    elif echo "$CPU_MODEL" | grep -qi "11th Gen\|Tiger Lake"; then
        CPU_GEN="11th Gen (Tiger Lake)"
        HAS_HYBRID=false
    elif echo "$CPU_MODEL" | grep -qi "10th Gen\|Comet Lake\|Ice Lake"; then
        CPU_GEN="10th Gen"
        HAS_HYBRID=false
    elif echo "$CPU_MODEL" | grep -qi "8th Gen\|9th Gen\|Coffee Lake"; then
        CPU_GEN="8th/9th Gen"
        HAS_HYBRID=false
    elif echo "$CPU_MODEL" | grep -qi "Intel"; then
        CPU_GEN="Intel (generación no identificada)"
        HAS_HYBRID=false
    else
        CPU_GEN="Desconocido"
        HAS_HYBRID=false
    fi
    
    # Advertir sobre undervolt bloqueado en gen 10+ con Plundervolt fix
    if echo "$CPU_GEN" | grep -qiE "1[0-5]th|Core Ultra|Arrow|Lunar|Meteor"; then
        UV_LIKELY_LOCKED=true
    else
        UV_LIKELY_LOCKED=false
    fi
}

detect_cores() {
    # Detectar P-cores y E-cores si existe arquitectura híbrida
    if [ "$HAS_HYBRID" = true ]; then
        TOTAL_CORES=$(nproc)
        P_CORES=0
        E_CORES=0
        
        # Arrays para mapear qué cores son P y cuáles E
        P_CORE_LIST=""
        E_CORE_LIST=""
        
        local use_heuristic=true
        
        if [ -f /sys/devices/system/cpu/cpu0/cpu_capacity ]; then
            # cpu_capacity: P-cores tienen 1024, E-cores tienen valor menor
            local p_count=0
            local e_count=0
            for cpu_dir in /sys/devices/system/cpu/cpu[0-9]*/; do
                local cpu_num
                cpu_num=$(basename "$cpu_dir" | tr -cd '0-9')
                local cap_file="${cpu_dir}cpu_capacity"
                if [ -f "$cap_file" ]; then
                    local cap
                    cap=$(cat "$cap_file" 2>/dev/null || echo "0")
                    if [ "$cap" -ge 1024 ]; then
                        p_count=$((p_count + 1))
                        P_CORE_LIST="${P_CORE_LIST} ${cpu_num}"
                    else
                        e_count=$((e_count + 1))
                        E_CORE_LIST="${E_CORE_LIST} ${cpu_num}"
                    fi
                fi
            done
            if [ $((p_count + e_count)) -eq "$TOTAL_CORES" ] && [ "$e_count" -gt 0 ]; then
                P_CORES=$p_count
                E_CORES=$e_count
                use_heuristic=false
            fi
        fi
        
        # Alternativa: lscpu -e con columna TYPE
        if [ "$use_heuristic" = true ] && command -v lscpu >/dev/null 2>&1; then
            local lscpu_output
            lscpu_output=$(lscpu -e 2>/dev/null)
            local p_count e_count
            p_count=$(echo "$lscpu_output" | grep -ci "performance" || echo "0")
            e_count=$(echo "$lscpu_output" | grep -ci "efficiency" || echo "0")
            if [ "$p_count" -gt 0 ] && [ "$e_count" -gt 0 ]; then
                P_CORES=$p_count
                E_CORES=$e_count
                # Extraer IDs de cores desde lscpu
                P_CORE_LIST=$(echo "$lscpu_output" | grep -i "performance" | awk '{print $1}' | tr '\n' ' ')
                E_CORE_LIST=$(echo "$lscpu_output" | grep -i "efficiency" | awk '{print $1}' | tr '\n' ' ')
                use_heuristic=false
            fi
        fi
        
        # Último recurso: heurística (menos fiable)
        if [ "$use_heuristic" = true ]; then
            echo -e "${YELLOW}⚠ No se pudo detectar P/E-cores exactamente, usando heurística${NC}"
            echo -e "${YELLOW}  Los límites por tipo de core pueden no aplicarse correctamente${NC}"
            if [ "$TOTAL_CORES" -ge 20 ]; then
                P_CORES=8; E_CORES=$((TOTAL_CORES - 8))
            elif [ "$TOTAL_CORES" -ge 14 ]; then
                P_CORES=6; E_CORES=$((TOTAL_CORES - 6))
            elif [ "$TOTAL_CORES" -ge 10 ]; then
                P_CORES=6; E_CORES=$((TOTAL_CORES - 6))
            else
                P_CORES=$TOTAL_CORES; E_CORES=0
            fi
            # Heurística: asumir secuencial (puede ser incorrecto)
            P_CORE_LIST=$(seq 0 $((P_CORES - 1)) | tr '\n' ' ')
            E_CORE_LIST=$(seq "$P_CORES" $((TOTAL_CORES - 1)) | tr '\n' ' ')
        fi
    else
        P_CORES=$CPU_CORES
        E_CORES=0
        P_CORE_LIST=$(seq 0 $((CPU_CORES - 1)) | tr '\n' ' ')
        E_CORE_LIST=""
    fi
}

detect_tjmax() {
    # Detectar Tjunction Max (temperatura máxima de fábrica del CPU)
    # Método 1: Leer desde MSR 0x1A2 bits 23:16
    if command -v rdmsr >/dev/null 2>&1 && [ -c /dev/cpu/0/msr ]; then
        local msr_tjmax
        msr_tjmax=$(rdmsr -f 23:16 0x1A2 2>/dev/null)
        if [ $? -eq 0 ] && [ -n "$msr_tjmax" ]; then
            TJMAX=$((16#$msr_tjmax))
            if [ "$TJMAX" -gt 0 ] && [ "$TJMAX" -le 120 ]; then
                return 0
            fi
        fi
    fi
    
    # Método 2: Leer desde lm-sensors (coretemp driver)
    if command -v sensors >/dev/null 2>&1; then
        local tj
        tj=$(sensors 2>/dev/null | grep -i "Package id 0" | grep -oP 'crit\s*=\s*\+\K[0-9]+' | head -1)
        if [ -n "$tj" ] && [ "$tj" -gt 0 ] && [ "$tj" -le 120 ]; then
            TJMAX=$tj
            return 0
        fi
    fi
    
    # Método 3: Leer desde thermal zone del kernel
    for tz in /sys/class/thermal/thermal_zone*/; do
        if [ -f "${tz}type" ]; then
            local tz_type
            tz_type=$(cat "${tz}type" 2>/dev/null)
            if echo "$tz_type" | grep -qi "x86_pkg_temp\|cpu"; then
                if [ -f "${tz}trip_point_0_temp" ]; then
                    local tj_mk
                    tj_mk=$(cat "${tz}trip_point_0_temp" 2>/dev/null || echo "0")
                    local tj_c=$((tj_mk / 1000))
                    if [ "$tj_c" -ge 80 ] && [ "$tj_c" -le 120 ]; then
                        TJMAX=$tj_c
                        return 0
                    fi
                fi
            fi
        fi
    done
    
    # Fallback: 100°C es el valor más común en CPUs Intel modernas
    TJMAX=100
}

# Temperatura de throttling configurada (se inicializa en read_current_power)
PROCHOT_TEMP=0

# ============================================================================
# FUNCIONES DE LECTURA DE ESTADO
# ============================================================================

read_current_undervolt() {
    if [ -f "$UNDERVOLT_CONF" ]; then
        # Parseo seguro: solo leer valores numéricos esperados (sin source)
        UV_CPU=$(grep -E '^UV_CPU=' "$UNDERVOLT_CONF" | head -1 | cut -d= -f2 | tr -cd '0-9-')
        UV_GPU=$(grep -E '^UV_GPU=' "$UNDERVOLT_CONF" | head -1 | cut -d= -f2 | tr -cd '0-9-')
        UV_CACHE=$(grep -E '^UV_CACHE=' "$UNDERVOLT_CONF" | head -1 | cut -d= -f2 | tr -cd '0-9-')
        UV_SA=$(grep -E '^UV_SA=' "$UNDERVOLT_CONF" | head -1 | cut -d= -f2 | tr -cd '0-9-')
        UV_IO=$(grep -E '^UV_IO=' "$UNDERVOLT_CONF" | head -1 | cut -d= -f2 | tr -cd '0-9-')
        # Asegurar valores por defecto si el parseo falla
        UV_CPU=${UV_CPU:-0}
        UV_GPU=${UV_GPU:-0}
        UV_CACHE=${UV_CACHE:-0}
        UV_SA=${UV_SA:-0}
        UV_IO=${UV_IO:-0}
    else
        # Valores por defecto (sin undervolt)
        UV_CPU=0
        UV_GPU=0
        UV_CACHE=0
        UV_SA=0
        UV_IO=0
    fi
}

read_current_power() {
    if [ -f "$POWER_CONF" ]; then
        # Parseo seguro: solo leer valores numéricos esperados (sin source)
        PL1_CURRENT=$(grep -E '^PL1_CURRENT=' "$POWER_CONF" | head -1 | cut -d= -f2 | tr -cd '0-9')
        PL2_CURRENT=$(grep -E '^PL2_CURRENT=' "$POWER_CONF" | head -1 | cut -d= -f2 | tr -cd '0-9')
        PL1_TIME=$(grep -E '^PL1_TIME=' "$POWER_CONF" | head -1 | cut -d= -f2 | tr -cd '0-9')
        PROCHOT_TEMP=$(grep -E '^PROCHOT_TEMP=' "$POWER_CONF" | head -1 | cut -d= -f2 | tr -cd '0-9')
        # Asegurar valores por defecto si el parseo falla
        PL1_CURRENT=${PL1_CURRENT:-0}
        PL2_CURRENT=${PL2_CURRENT:-0}
        PL1_TIME=${PL1_TIME:-28}
        PROCHOT_TEMP=${PROCHOT_TEMP:-$TJMAX}
    else
        # Detectar TDP actual
        if [ -f /sys/class/powercap/intel-rapl/intel-rapl:0/constraint_0_power_limit_uw ]; then
            PL1_CURRENT=$(($(cat /sys/class/powercap/intel-rapl/intel-rapl:0/constraint_0_power_limit_uw) / 1000000))
            PL2_CURRENT=$(($(cat /sys/class/powercap/intel-rapl/intel-rapl:0/constraint_1_power_limit_uw) / 1000000))
            PL1_TIME=$(($(cat /sys/class/powercap/intel-rapl/intel-rapl:0/constraint_0_time_window_us) / 1000000))
        else
            PL1_CURRENT=0
            PL2_CURRENT=0
            PL1_TIME=28
        fi
        
        # Por defecto, throttling a la temperatura máxima de fábrica
        PROCHOT_TEMP=$TJMAX
    fi
}

read_current_freq() {
    # Leer frecuencias actuales
    MIN_FREQ=$(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_min_freq 2>/dev/null || echo "0")
    MAX_FREQ=$(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_max_freq 2>/dev/null || echo "0")
    
    # Convertir de KHz a MHz
    MIN_FREQ=$((MIN_FREQ / 1000))
    MAX_FREQ=$((MAX_FREQ / 1000))
    
    # Leer frecuencias máximas del hardware
    CPUINFO_MAX=$(cat /sys/devices/system/cpu/cpu0/cpufreq/cpuinfo_max_freq 2>/dev/null || echo "0")
    CPUINFO_MAX=$((CPUINFO_MAX / 1000))
    
    if [ -f "$FREQ_CONF" ]; then
        # Parseo seguro: solo leer valores numéricos esperados (sin source)
        TARGET_MAX_FREQ=$(grep -E '^TARGET_MAX_FREQ=' "$FREQ_CONF" | head -1 | cut -d= -f2 | tr -cd '0-9')
        TARGET_MIN_FREQ=$(grep -E '^TARGET_MIN_FREQ=' "$FREQ_CONF" | head -1 | cut -d= -f2 | tr -cd '0-9')
        P_CORE_MAX=$(grep -E '^P_CORE_MAX=' "$FREQ_CONF" | head -1 | cut -d= -f2 | tr -cd '0-9')
        E_CORE_MAX=$(grep -E '^E_CORE_MAX=' "$FREQ_CONF" | head -1 | cut -d= -f2 | tr -cd '0-9')
        # Asegurar valores por defecto si el parseo falla
        TARGET_MAX_FREQ=${TARGET_MAX_FREQ:-$MAX_FREQ}
        TARGET_MIN_FREQ=${TARGET_MIN_FREQ:-$MIN_FREQ}
        P_CORE_MAX=${P_CORE_MAX:-$MAX_FREQ}
        E_CORE_MAX=${E_CORE_MAX:-$MAX_FREQ}
    else
        TARGET_MAX_FREQ=$MAX_FREQ
        TARGET_MIN_FREQ=$MIN_FREQ
        P_CORE_MAX=$MAX_FREQ
        E_CORE_MAX=$MAX_FREQ
    fi
}

read_current_temps() {
    # Leer temperaturas actuales
    if command -v sensors >/dev/null 2>&1; then
        TEMP_OUTPUT=$(sensors 2>/dev/null)
        CPU_TEMP=$(echo "$TEMP_OUTPUT" | grep -i "Package id 0" | grep -o "+[0-9]*" | head -1 | tr -d '+')
        [ -z "$CPU_TEMP" ] && CPU_TEMP=$(echo "$TEMP_OUTPUT" | grep -i "Core 0" | grep -o "+[0-9]*" | head -1 | tr -d '+')
        [ -z "$CPU_TEMP" ] && CPU_TEMP="N/A"
    else
        CPU_TEMP="N/A"
    fi
}

# ============================================================================
# LECTURA DE TECNOLOGÍAS DE GESTIÓN (SpeedStep, Speed Shift, C1E, BD-PROCHOT)
# ============================================================================

read_power_technologies() {
    # Inicializar variables
    SPEEDSTEP_ENABLED="N/A"
    SPEEDSHIFT_ENABLED="N/A"
    HWP_ENABLED="N/A"
    C1E_ENABLED="N/A"
    BD_PROCHOT_ENABLED="N/A"
    EPP_CURRENT="N/A"
    EPP_AVAILABLE=""
    PSTATE_DRIVER="N/A"
    PSTATE_STATUS="N/A"
    HWP_HIGHEST=0
    HWP_GUARANTEED=0
    HWP_EFFICIENT=0
    HWP_LOWEST=0

    # --- Driver en uso ---
    if [ -f /sys/devices/system/cpu/cpu0/cpufreq/scaling_driver ]; then
        PSTATE_DRIVER=$(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_driver 2>/dev/null || echo "N/A")
    fi
    if [ -f /sys/devices/system/cpu/intel_pstate/status ]; then
        PSTATE_STATUS=$(cat /sys/devices/system/cpu/intel_pstate/status 2>/dev/null || echo "N/A")
    fi

    # --- EPP vía sysfs (método preferido, no necesita MSR) ---
    if [ -f /sys/devices/system/cpu/cpu0/cpufreq/energy_performance_preference ]; then
        EPP_CURRENT=$(cat /sys/devices/system/cpu/cpu0/cpufreq/energy_performance_preference 2>/dev/null || echo "N/A")
    fi
    if [ -f /sys/devices/system/cpu/cpu0/cpufreq/energy_performance_available_preferences ]; then
        EPP_AVAILABLE=$(cat /sys/devices/system/cpu/cpu0/cpufreq/energy_performance_available_preferences 2>/dev/null || echo "")
    fi

    # --- Turbo Boost vía sysfs ---
    if [ -f /sys/devices/system/cpu/intel_pstate/no_turbo ]; then
        local no_turbo
        no_turbo=$(cat /sys/devices/system/cpu/intel_pstate/no_turbo 2>/dev/null || echo "0")
        TURBO_ENABLED=$([ "$no_turbo" = "0" ] && echo "true" || echo "false")
    else
        TURBO_ENABLED="N/A"
    fi

    # --- HWP Dynamic Boost vía sysfs ---
    HWP_DYNAMIC_BOOST="N/A"
    if [ -f /sys/devices/system/cpu/intel_pstate/hwp_dynamic_boost ]; then
        local hdb
        hdb=$(cat /sys/devices/system/cpu/intel_pstate/hwp_dynamic_boost 2>/dev/null || echo "0")
        HWP_DYNAMIC_BOOST=$([ "$hdb" = "1" ] && echo "true" || echo "false")
    fi

    # --- MSR reads (requiere msr-tools + módulo msr) ---
    if command -v rdmsr >/dev/null 2>&1 && [ -c /dev/cpu/0/msr ]; then
        # MSR 0x1AA - MSR_MISC_PWR_MGMT: EIST/SpeedStep status
        local misc_pwr
        misc_pwr=$(rdmsr 0x1AA 2>/dev/null)
        if [ -n "$misc_pwr" ]; then
            local misc_val=$((16#$misc_pwr))
            # Bit 0: EIST hardware coordination enable
            SPEEDSTEP_ENABLED=$([ $((misc_val & 0x1)) -eq 0 ] && echo "true" || echo "false")
        fi

        # MSR 0x770 - IA32_PM_ENABLE: HWP/Speed Shift enable
        local pm_enable
        pm_enable=$(rdmsr 0x770 2>/dev/null)
        if [ -n "$pm_enable" ]; then
            local pm_val=$((16#$pm_enable))
            HWP_ENABLED=$([ $((pm_val & 0x1)) -eq 1 ] && echo "true" || echo "false")
            SPEEDSHIFT_ENABLED=$HWP_ENABLED
        fi

        # MSR 0x1FC - MSR_POWER_CTL: C1E y BD-PROCHOT
        local power_ctl
        power_ctl=$(rdmsr 0x1FC 2>/dev/null)
        if [ -n "$power_ctl" ]; then
            local pctl_val=$((16#$power_ctl))
            # Bit 0: BD PROCHOT (Bi-Directional Processor Hot)
            BD_PROCHOT_ENABLED=$([ $((pctl_val & 0x1)) -eq 1 ] && echo "true" || echo "false")
            # Bit 1: C1E auto-promotion enable
            C1E_ENABLED=$([ $((pctl_val & 0x2)) -eq 2 ] && echo "true" || echo "false")
        fi

        # MSR 0x771 - IA32_HWP_CAPABILITIES (solo si HWP habilitado)
        if [ "$HWP_ENABLED" = "true" ]; then
            local hwp_caps
            hwp_caps=$(rdmsr 0x771 2>/dev/null)
            if [ -n "$hwp_caps" ]; then
                local caps_val=$((16#$hwp_caps))
                HWP_HIGHEST=$(( (caps_val >> 0) & 0xFF ))
                HWP_GUARANTEED=$(( (caps_val >> 8) & 0xFF ))
                HWP_EFFICIENT=$(( (caps_val >> 16) & 0xFF ))
                HWP_LOWEST=$(( (caps_val >> 24) & 0xFF ))
            fi
        fi
    fi
}

# ============================================================================
# DETECCIÓN DE THROTTLE REASONS (MSR 0x64F + IA32_THERM_STATUS)
# ============================================================================

read_throttle_reasons() {
    # Inicializar
    THROTTLE_REASONS=""
    THROTTLE_PROCHOT=false
    THROTTLE_THERMAL=false
    THROTTLE_PL1=false
    THROTTLE_PL2=false
    THROTTLE_TURBO=false
    THROTTLE_EDP=false
    THROTTLE_VR_THERMAL=false
    THROTTLE_MAX_TURBO=false

    if ! command -v rdmsr >/dev/null 2>&1 || [ ! -c /dev/cpu/0/msr ]; then
        THROTTLE_REASONS="N/A (msr-tools no disponible)"
        return
    fi

    # --- MSR 0x19C: IA32_THERM_STATUS (estado térmico del core) ---
    local therm_status
    therm_status=$(rdmsr -p 0 0x19C 2>/dev/null)
    if [ -n "$therm_status" ]; then
        local ts_val=$((16#$therm_status))
        # Bit 0: Thermal Status (throttling activo ahora)
        [ $((ts_val & 0x1)) -eq 1 ] && THROTTLE_THERMAL=true
        # Bit 2: PROCHOT# or FORCEPR# event
        [ $((ts_val & 0x4)) -eq 4 ] && THROTTLE_PROCHOT=true
    fi

    # --- MSR 0x1B1: IA32_PACKAGE_THERM_STATUS ---
    local pkg_therm
    pkg_therm=$(rdmsr 0x1B1 2>/dev/null)
    if [ -n "$pkg_therm" ]; then
        local pt_val=$((16#$pkg_therm))
        # Bit 0: Thermal Status
        [ $((pt_val & 0x1)) -eq 1 ] && THROTTLE_THERMAL=true
        # Bit 10: Power Limit Notification (PL1 en paquete)
        [ $((pt_val & 0x400)) -ne 0 ] && THROTTLE_PL1=true
    fi

    # --- MSR 0x64F: MSR_CORE_PERF_LIMIT_REASONS ---
    # (Este MSR no existe en todos los procesadores)
    local perf_limit
    perf_limit=$(rdmsr -p 0 0x64F 2>/dev/null)
    if [ -n "$perf_limit" ]; then
        local pl_val=$((16#$perf_limit))

        # Bits de STATUS (activos AHORA): bits 0-15
        # Bit 0: PROCHOT Status
        [ $((pl_val & 0x1)) -ne 0 ] && THROTTLE_PROCHOT=true
        # Bit 1: Thermal Status
        [ $((pl_val & 0x2)) -ne 0 ] && THROTTLE_THERMAL=true
        # Bit 4: Graphics Driver Status (iGPU limita CPU)
        # Bit 5: Autonomous Utilization / RATL Status
        # Bit 6: VR Therm Alert Status
        [ $((pl_val & 0x40)) -ne 0 ] && THROTTLE_VR_THERMAL=true
        # Bit 8: Electrical Design Point Status
        [ $((pl_val & 0x100)) -ne 0 ] && THROTTLE_EDP=true
        # Bit 10: PL1 Status
        [ $((pl_val & 0x400)) -ne 0 ] && THROTTLE_PL1=true
        # Bit 11: PL2 Status
        [ $((pl_val & 0x800)) -ne 0 ] && THROTTLE_PL2=true
        # Bit 12: Max Turbo Limit Status
        [ $((pl_val & 0x1000)) -ne 0 ] && THROTTLE_MAX_TURBO=true
        # Bit 13: Turbo Transition Attenuation Status
        # Bit 14: Core Max n-core Turbo Limit Status
        [ $((pl_val & 0x4000)) -ne 0 ] && THROTTLE_TURBO=true

        # Bits de LOG (han ocurrido desde último reset): bits 16-31
        local log_prochot=$(( (pl_val >> 16) & 0x1 ))
        local log_thermal=$(( (pl_val >> 17) & 0x1 ))
        local log_pl1=$(( (pl_val >> 26) & 0x1 ))
        local log_pl2=$(( (pl_val >> 27) & 0x1 ))
        local log_turbo=$(( (pl_val >> 28) & 0x1 ))
        local log_edp=$(( (pl_val >> 24) & 0x1 ))
        local log_vr=$(( (pl_val >> 22) & 0x1 ))

        # Construir cadena de razones
        THROTTLE_REASONS=""
        # Activos ahora
        [ "$THROTTLE_PROCHOT" = true ] && THROTTLE_REASONS="${THROTTLE_REASONS}${RED}PROCHOT${NC} "
        [ "$THROTTLE_THERMAL" = true ] && THROTTLE_REASONS="${THROTTLE_REASONS}${RED}THERMAL${NC} "
        [ "$THROTTLE_PL1" = true ] && THROTTLE_REASONS="${THROTTLE_REASONS}${RED}PL1${NC} "
        [ "$THROTTLE_PL2" = true ] && THROTTLE_REASONS="${THROTTLE_REASONS}${RED}PL2${NC} "
        [ "$THROTTLE_EDP" = true ] && THROTTLE_REASONS="${THROTTLE_REASONS}${RED}EDP${NC} "
        [ "$THROTTLE_VR_THERMAL" = true ] && THROTTLE_REASONS="${THROTTLE_REASONS}${RED}VR-THERM${NC} "
        [ "$THROTTLE_TURBO" = true ] && THROTTLE_REASONS="${THROTTLE_REASONS}${YELLOW}TURBO-LIMIT${NC} "
        [ "$THROTTLE_MAX_TURBO" = true ] && THROTTLE_REASONS="${THROTTLE_REASONS}${YELLOW}MAX-TURBO${NC} "

        # Log (han ocurrido en el pasado)
        THROTTLE_LOG=""
        [ "$log_prochot" -eq 1 ] && THROTTLE_LOG="${THROTTLE_LOG}PROCHOT "
        [ "$log_thermal" -eq 1 ] && THROTTLE_LOG="${THROTTLE_LOG}THERMAL "
        [ "$log_pl1" -eq 1 ] && THROTTLE_LOG="${THROTTLE_LOG}PL1 "
        [ "$log_pl2" -eq 1 ] && THROTTLE_LOG="${THROTTLE_LOG}PL2 "
        [ "$log_edp" -eq 1 ] && THROTTLE_LOG="${THROTTLE_LOG}EDP "
        [ "$log_vr" -eq 1 ] && THROTTLE_LOG="${THROTTLE_LOG}VR-THERM "
        [ "$log_turbo" -eq 1 ] && THROTTLE_LOG="${THROTTLE_LOG}TURBO "

        [ -z "$THROTTLE_REASONS" ] && THROTTLE_REASONS="${GREEN}Ninguno${NC}"
        [ -z "$THROTTLE_LOG" ] && THROTTLE_LOG="Ninguno"
    else
        THROTTLE_REASONS="N/A (MSR 0x64F no disponible)"
        THROTTLE_LOG="N/A"
    fi
}

# ============================================================================
# TOGGLE DE TECNOLOGÍAS (SpeedStep, C1E, BD-PROCHOT, EPP, Turbo)
# ============================================================================

toggle_bd_prochot() {
    local new_state=$1  # "enable" o "disable"
    if ! command -v rdmsr >/dev/null 2>&1 || ! command -v wrmsr >/dev/null 2>&1 || [ ! -c /dev/cpu/0/msr ]; then
        echo -e "${RED}✗ Requiere msr-tools y módulo msr cargado${NC}"
        return 1
    fi
    local power_ctl
    power_ctl=$(rdmsr 0x1FC 2>/dev/null)
    if [ -z "$power_ctl" ]; then
        echo -e "${RED}✗ No se pudo leer MSR 0x1FC${NC}"
        return 1
    fi
    local pctl_val=$((16#$power_ctl))
    if [ "$new_state" = "enable" ]; then
        pctl_val=$((pctl_val | 0x1))
    else
        pctl_val=$((pctl_val & ~0x1))
    fi
    local new_hex
    new_hex=$(printf "0x%x" $pctl_val)
    if wrmsr -a 0x1FC "$new_hex" 2>/dev/null; then
        echo -e "${GREEN}✓ BD-PROCHOT: ${new_state}d${NC}"
        UNSAVED_CHANGES=true
    else
        echo -e "${RED}✗ Error escribiendo MSR 0x1FC${NC}"
        return 1
    fi
}

toggle_c1e() {
    local new_state=$1
    if ! command -v rdmsr >/dev/null 2>&1 || ! command -v wrmsr >/dev/null 2>&1 || [ ! -c /dev/cpu/0/msr ]; then
        echo -e "${RED}✗ Requiere msr-tools y módulo msr cargado${NC}"
        return 1
    fi
    local power_ctl
    power_ctl=$(rdmsr 0x1FC 2>/dev/null)
    if [ -z "$power_ctl" ]; then
        echo -e "${RED}✗ No se pudo leer MSR 0x1FC${NC}"
        return 1
    fi
    local pctl_val=$((16#$power_ctl))
    if [ "$new_state" = "enable" ]; then
        pctl_val=$((pctl_val | 0x2))
    else
        pctl_val=$((pctl_val & ~0x2))
    fi
    local new_hex
    new_hex=$(printf "0x%x" $pctl_val)
    if wrmsr -a 0x1FC "$new_hex" 2>/dev/null; then
        echo -e "${GREEN}✓ C1E auto-promotion: ${new_state}d${NC}"
        UNSAVED_CHANGES=true
    else
        echo -e "${RED}✗ Error escribiendo MSR 0x1FC${NC}"
        return 1
    fi
}

toggle_turbo() {
    local new_state=$1  # "enable" o "disable"
    if [ -f /sys/devices/system/cpu/intel_pstate/no_turbo ]; then
        if [ "$new_state" = "enable" ]; then
            echo 0 > /sys/devices/system/cpu/intel_pstate/no_turbo 2>/dev/null
        else
            echo 1 > /sys/devices/system/cpu/intel_pstate/no_turbo 2>/dev/null
        fi
        echo -e "${GREEN}✓ Turbo Boost: ${new_state}d${NC}"
        UNSAVED_CHANGES=true
    else
        echo -e "${RED}✗ intel_pstate/no_turbo no disponible${NC}"
        return 1
    fi
}

set_epp() {
    local epp_value=$1  # "performance", "balance_performance", "balance_power", "power"
    local errors=0
    for epp_file in /sys/devices/system/cpu/cpu*/cpufreq/energy_performance_preference; do
        if [ -f "$epp_file" ]; then
            if ! echo "$epp_value" > "$epp_file" 2>/dev/null; then
                errors=$((errors + 1))
            fi
        fi
    done
    if [ "$errors" -eq 0 ]; then
        echo -e "${GREEN}✓ EPP configurado: ${epp_value}${NC}"
        UNSAVED_CHANGES=true
    else
        echo -e "${YELLOW}⚠ EPP: $errors core(s) no aceptaron el cambio${NC}"
    fi
}

# ============================================================================
# FUNCIONES DE APLICACIÓN
# ============================================================================

apply_undervolt() {
    if ! command -v intel-undervolt >/dev/null 2>&1; then
        echo -e "${RED}intel-undervolt no está instalado${NC}"
        echo -e "${YELLOW}  Instalar con: apt install intel-undervolt${NC}"
        return 1
    fi
    
    # Crear archivo de configuración temporal
    local tmp_conf="/tmp/nothrottle-uv-$$.conf"
    cat > "$tmp_conf" << EOF
# Undervolt configuration - Generated by NoThrottle
undervolt 0 'CPU' $UV_CPU
undervolt 1 'GPU' $UV_GPU
undervolt 2 'CPU Cache' $UV_CACHE
undervolt 3 'System Agent' $UV_SA
undervolt 4 'Analog I/O' $UV_IO
EOF
    
    # Aplicar INMEDIATAMENTE y capturar errores
    local output
    output=$(intel-undervolt apply -c "$tmp_conf" 2>&1)
    local ret=$?
    
    # Limpiar archivo temporal siempre
    rm -f "$tmp_conf"
    
    if [ $ret -eq 0 ]; then
        echo -e "${GREEN}✓ Undervolt aplicado AHORA (temporal)${NC}"
        echo -e "${YELLOW}  Los cambios están activos pero NO son persistentes${NC}"
        
        # Verificar si realmente se aplicó leyendo los valores actuales
        local read_output
        read_output=$(intel-undervolt read 2>/dev/null)
        if [ -n "$read_output" ]; then
            echo -e "${CYAN}  Valores leídos del hardware:${NC}"
            echo "$read_output" | while IFS= read -r line; do
                echo -e "    $line"
            done
        fi
        
        UNSAVED_CHANGES=true
        return 0
    else
        echo -e "${RED}✗ Error aplicando undervolt${NC}"
        if echo "$output" | grep -qi "locked\|denied\|permission"; then
            echo -e "${YELLOW}  El undervolt puede estar bloqueado por el firmware (BIOS/UEFI)${NC}"
            echo -e "${YELLOW}  Algunas CPUs recientes bloquean undervolt por seguridad (Plundervolt)${NC}"
        else
            echo -e "${YELLOW}  Salida: $output${NC}"
        fi
        return 1
    fi
}

apply_power_limits() {
    if [ ! -d /sys/class/powercap/intel-rapl/intel-rapl:0/ ]; then
        echo -e "${RED}RAPL no disponible en este sistema${NC}"
        return 1
    fi
    
    local errors=0
    
    # Aplicar PL1 INMEDIATAMENTE
    if [ "$PL1_CURRENT" -gt 0 ]; then
        if ! echo $((PL1_CURRENT * 1000000)) > /sys/class/powercap/intel-rapl/intel-rapl:0/constraint_0_power_limit_uw 2>/tmp/nothrottle_err; then
            echo -e "${RED}✗ Error aplicando PL1: $(cat /tmp/nothrottle_err 2>/dev/null)${NC}"
            echo -e "${YELLOW}  Posibles causas: Secure Boot activo, kernel bloqueando RAPL, o permisos insuficientes${NC}"
            errors=$((errors + 1))
        fi
    fi
    
    # Aplicar PL2 INMEDIATAMENTE
    if [ "$PL2_CURRENT" -gt 0 ]; then
        if ! echo $((PL2_CURRENT * 1000000)) > /sys/class/powercap/intel-rapl/intel-rapl:0/constraint_1_power_limit_uw 2>/tmp/nothrottle_err; then
            echo -e "${RED}✗ Error aplicando PL2: $(cat /tmp/nothrottle_err 2>/dev/null)${NC}"
            errors=$((errors + 1))
        fi
    fi
    
    # Aplicar ventana de tiempo INMEDIATAMENTE
    if ! echo $((PL1_TIME * 1000000)) > /sys/class/powercap/intel-rapl/intel-rapl:0/constraint_0_time_window_us 2>/tmp/nothrottle_err; then
        echo -e "${RED}✗ Error aplicando PL1 Time Window: $(cat /tmp/nothrottle_err 2>/dev/null)${NC}"
        errors=$((errors + 1))
    fi
    
    rm -f /tmp/nothrottle_err
    
    if [ "$errors" -gt 0 ]; then
        echo -e "${RED}✗ $errors error(es) aplicando límites de potencia${NC}"
        echo -e "${YELLOW}  Verifica: Secure Boot puede bloquear escrituras RAPL${NC}"
        return 1
    fi
    
    # Verificar que los valores se aplicaron realmente
    local actual_pl1 actual_pl2
    actual_pl1=$(($(cat /sys/class/powercap/intel-rapl/intel-rapl:0/constraint_0_power_limit_uw 2>/dev/null || echo "0") / 1000000))
    actual_pl2=$(($(cat /sys/class/powercap/intel-rapl/intel-rapl:0/constraint_1_power_limit_uw 2>/dev/null || echo "0") / 1000000))
    
    if [ "$PL1_CURRENT" -gt 0 ] && [ "$actual_pl1" -ne "$PL1_CURRENT" ]; then
        echo -e "${YELLOW}⚠ PL1 solicitado: ${PL1_CURRENT}W, pero el valor real es: ${actual_pl1}W${NC}"
        echo -e "${YELLOW}  El firmware puede estar limitando el valor${NC}"
    fi
    
    if [ "$PL2_CURRENT" -gt 0 ] && [ "$actual_pl2" -ne "$PL2_CURRENT" ]; then
        echo -e "${YELLOW}⚠ PL2 solicitado: ${PL2_CURRENT}W, pero el valor real es: ${actual_pl2}W${NC}"
    fi
    
    echo -e "${GREEN}✓ Límites de potencia aplicados AHORA (temporal)${NC}"
    echo -e "${YELLOW}  Los cambios están activos pero NO son persistentes${NC}"
    UNSAVED_CHANGES=true
}

apply_frequency_limits() {
    local errors=0
    
    # Aplicar frecuencia máxima a todos los cores INMEDIATAMENTE
    for cpu in /sys/devices/system/cpu/cpu*/cpufreq/scaling_max_freq; do
        if [ -f "$cpu" ]; then
            if ! echo $((TARGET_MAX_FREQ * 1000)) > "$cpu" 2>/dev/null; then
                errors=$((errors + 1))
            fi
        fi
    done
    
    # Aplicar frecuencia mínima INMEDIATAMENTE
    for cpu in /sys/devices/system/cpu/cpu*/cpufreq/scaling_min_freq; do
        if [ -f "$cpu" ]; then
            if ! echo $((TARGET_MIN_FREQ * 1000)) > "$cpu" 2>/dev/null; then
                errors=$((errors + 1))
            fi
        fi
    done
    
    # Si hay arquitectura híbrida, aplicar límites específicos INMEDIATAMENTE
    if [ "$HAS_HYBRID" = true ] && [ "$E_CORES" -gt 0 ]; then
        # P-cores (usando lista real detectada)
        for i in $P_CORE_LIST; do
            if [ -f "/sys/devices/system/cpu/cpu$i/cpufreq/scaling_max_freq" ]; then
                if ! echo $((P_CORE_MAX * 1000)) > "/sys/devices/system/cpu/cpu$i/cpufreq/scaling_max_freq" 2>/dev/null; then
                    errors=$((errors + 1))
                fi
            fi
        done
        
        # E-cores (usando lista real detectada)
        for i in $E_CORE_LIST; do
            if [ -f "/sys/devices/system/cpu/cpu$i/cpufreq/scaling_max_freq" ]; then
                if ! echo $((E_CORE_MAX * 1000)) > "/sys/devices/system/cpu/cpu$i/cpufreq/scaling_max_freq" 2>/dev/null; then
                    errors=$((errors + 1))
                fi
            fi
        done
    fi
    
    if [ "$errors" -gt 0 ]; then
        echo -e "${YELLOW}⚠ $errors error(es) al aplicar frecuencias (algunos cores pueden no haberse configurado)${NC}"
        echo -e "${YELLOW}  Verifica que el governor actual permita cambios de frecuencia${NC}"
    fi
    
    # Verificar al menos un core
    local actual_max
    actual_max=$(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_max_freq 2>/dev/null || echo "0")
    actual_max=$((actual_max / 1000))
    if [ "$actual_max" -ne "$TARGET_MAX_FREQ" ] && [ "$actual_max" -gt 0 ]; then
        echo -e "${YELLOW}⚠ Frecuencia máx. solicitada: ${TARGET_MAX_FREQ}MHz, real: ${actual_max}MHz${NC}"
    fi
    
    echo -e "${GREEN}✓ Límites de frecuencia aplicados AHORA (temporal)${NC}"
    echo -e "${YELLOW}  Los cambios están activos pero NO son persistentes${NC}"
    UNSAVED_CHANGES=true
}

apply_prochot() {
    # PROCHOT: el usuario elige una temperatura en °C (ej. 90°C)
    # Internamente se convierte a offset MSR: offset = Tjmax - temperatura_deseada
    # Se escribe en MSR 0x1A2 (IA32_TEMPERATURE_TARGET), bits 29:24
    
    local target_offset=$((TJMAX - PROCHOT_TEMP))
    
    if [ "$target_offset" -eq 0 ]; then
        echo -e "${GREEN}✓ Throttling a ${PROCHOT_TEMP}°C (Tjmax de fábrica, sin offset)${NC}"
        # Aún así escribimos 0 para resetear cualquier offset previo
    fi
    
    # Verificar si msr-tools está disponible
    if ! command -v rdmsr >/dev/null 2>&1 || ! command -v wrmsr >/dev/null 2>&1; then
        echo -e "${RED}✗ Ajuste de temperatura de throttling requiere msr-tools (rdmsr/wrmsr)${NC}"
        echo -e "${YELLOW}  Instalar con: apt install msr-tools${NC}"
        echo -e "${YELLOW}  El cambio NO se ha aplicado${NC}"
        return 1
    fi
    
    # Cargar módulo msr si no está cargado
    if [ ! -c /dev/cpu/0/msr ]; then
        modprobe msr 2>/dev/null
        if [ ! -c /dev/cpu/0/msr ]; then
            echo -e "${RED}✗ No se pudo cargar el módulo MSR${NC}"
            echo -e "${YELLOW}  Posible causa: Secure Boot bloquea módulos no firmados${NC}"
            return 1
        fi
    fi
    
    # Asegurar que el offset está en rango válido (0-63, 6 bits)
    if [ "$target_offset" -lt 0 ]; then
        target_offset=0
        echo -e "${YELLOW}⚠ Temperatura ajustada a ${TJMAX}°C (no se puede superar Tjmax por offset)${NC}"
    elif [ "$target_offset" -gt 63 ]; then
        target_offset=63
        local actual_temp=$((TJMAX - 63))
        echo -e "${YELLOW}⚠ Temperatura ajustada a ${actual_temp}°C (offset máximo de hardware: 63°C)${NC}"
    fi
    
    # Leer valor completo del MSR 0x1A2
    local full_msr
    full_msr=$(rdmsr 0x1A2 2>/dev/null)
    if [ $? -ne 0 ] || [ -z "$full_msr" ]; then
        echo -e "${RED}✗ No se pudo leer MSR 0x1A2 (IA32_TEMPERATURE_TARGET)${NC}"
        echo -e "${YELLOW}  Esta CPU puede no soportar ajuste de temperatura de throttling${NC}"
        return 1
    fi
    
    local full_val=$((16#$full_msr))
    # Limpiar bits 29:24 y establecer nuevo offset
    full_val=$(( (full_val & ~(0x3F << 24)) | (target_offset << 24) ))
    local new_hex
    new_hex=$(printf "0x%x" $full_val)
    
    if wrmsr -a 0x1A2 "$new_hex" 2>/dev/null; then
        local actual_temp=$((TJMAX - target_offset))
        echo -e "${GREEN}✓ Temperatura de throttling configurada: ${actual_temp}°C${NC}"
        echo -e "${CYAN}  (Tjmax: ${TJMAX}°C - Offset: ${target_offset}°C = ${actual_temp}°C)${NC}"
    else
        echo -e "${RED}✗ Error escribiendo MSR 0x1A2${NC}"
        echo -e "${YELLOW}  El kernel puede estar bloqueando escrituras MSR${NC}"
        return 1
    fi
    
    UNSAVED_CHANGES=true
}

