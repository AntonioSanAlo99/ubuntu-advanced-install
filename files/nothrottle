#!/bin/bash
set -o pipefail
# nothrottle - ThrottleStop-like power management for Linux
# Gestión completa de CPU Intel: Undervolt, TDP, PROCHOT, Frecuencias
#
# Instalación: sudo nothrottle --install
# Uso:         sudo nothrottle [opciones]
#
# Ubicaciones tras instalación:
#   Binario:   /usr/local/bin/nothrottle
#   Config:    /etc/nothrottle/
#   Servicio:  /etc/systemd/system/nothrottle.service
#   Aplicador: /usr/local/bin/nothrottle-apply
#   Man page:  /usr/local/share/man/man8/nothrottle.8

VERSION="1.3.0"
SCRIPT_PATH="$(readlink -f "$0")"

# Limpieza al salir (trap para archivos temporales)
cleanup() {
    rm -f /tmp/nothrottle-uv-*.conf /tmp/nothrottle_err 2>/dev/null
}
trap cleanup EXIT

# Variables globales inicializadas
UV_LIKELY_LOCKED=false
HAS_HYBRID=false
P_CORE_LIST=""
E_CORE_LIST=""
P_CORES=0
E_CORES=0
CPUINFO_MAX=0
CPU_CORES=1
CPU_MODEL="Unknown"
CPU_GEN="Unknown"

# Colores
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color
BOLD='\033[1m'
DIM='\033[2m'

# ============================================================================
# LÍMITES DE SEGURIDAD (basados en ThrottleStop)
# ============================================================================

# Undervolt (mV) - Valores NEGATIVOS
readonly UV_MIN=-250      # Máximo undervolt permitido
readonly UV_MAX=50        # Máximo overvolt permitido (generalmente no recomendado)
readonly UV_SAFE=-125     # Límite "seguro" recomendado

# TDP/Power Limits (Watts)
readonly PL_MIN=5         # Mínimo TDP (5W para ultrabooks extremos)
readonly PL_MAX=125       # Máximo TDP (125W para desktop replacement)
readonly PL_SAFE_MIN=15   # Mínimo recomendado
readonly PL_SAFE_MAX=65   # Máximo recomendado para laptops

# Time Window (segundos)
readonly TIME_MIN=1       # Mínimo 1 segundo
readonly TIME_MAX=128     # Máximo 128 segundos (ThrottleStop limit)
readonly TIME_DEFAULT=28  # Valor por defecto Intel

# PROCHOT / Temperatura de Throttling (°C)
# El CPU tiene una Tjunction max (Tjmax) de fábrica (típicamente 100°C).
# El usuario elige a qué temperatura quiere que empiece el throttling.
# Internamente se calcula: offset = Tjmax - temperatura_deseada
readonly PROCHOT_TEMP_MIN=70    # Mínima temperatura de throttling permitida
readonly PROCHOT_TEMP_MAX=105   # Máxima temperatura de throttling permitida
TJMAX=100                        # Se detecta automáticamente al iniciar

# Frecuencias (MHz)
readonly FREQ_MIN=400     # Mínima frecuencia absoluta
readonly FREQ_MAX=6000    # Máxima frecuencia teórica (futuras CPUs)

# ============================================================================
# FUNCIONES DE VALIDACIÓN
# ============================================================================

validate_number() {
    local value=$1
    # Verificar que es un número (positivo o negativo)
    if ! [[ "$value" =~ ^-?[0-9]+$ ]]; then
        return 1
    fi
    return 0
}

validate_undervolt() {
    local value=$1
    local component=$2
    
    if ! validate_number "$value"; then
        echo -e "${RED}✗ Error: Debe ser un número${NC}"
        return 1
    fi
    
    if [ "$value" -lt $UV_MIN ]; then
        echo -e "${RED}✗ Error: Undervolt demasiado alto (límite: ${UV_MIN}mV)${NC}"
        echo -e "${YELLOW}  Valores menores a ${UV_MIN}mV son peligrosos${NC}"
        return 1
    fi
    
    if [ "$value" -gt $UV_MAX ]; then
        echo -e "${RED}✗ Error: Overvolt no recomendado (límite: ${UV_MAX}mV)${NC}"
        echo -e "${YELLOW}  Valores positivos pueden dañar el CPU${NC}"
        return 1
    fi
    
    # Advertencia si está fuera del rango seguro
    if [ "$value" -lt $UV_SAFE ] && [ "$value" -ge $UV_MIN ]; then
        echo -e "${YELLOW}⚠ Advertencia: Undervolt muy agresivo ($value mV)${NC}"
        echo -e "${YELLOW}  Rango seguro: 0 a ${UV_SAFE}mV${NC}"
        read -p "  ¿Continuar de todos modos? (s/n): " confirm
        if [ "$confirm" != "s" ] && [ "$confirm" != "S" ]; then
            return 1
        fi
    fi
    
    return 0
}

validate_power_limit() {
    local value=$1
    local type=$2  # PL1 o PL2
    
    if ! validate_number "$value"; then
        echo -e "${RED}✗ Error: Debe ser un número${NC}"
        return 1
    fi
    
    if [ "$value" -lt $PL_MIN ]; then
        echo -e "${RED}✗ Error: TDP demasiado bajo (mínimo: ${PL_MIN}W)${NC}"
        return 1
    fi
    
    if [ "$value" -gt $PL_MAX ]; then
        echo -e "${RED}✗ Error: TDP demasiado alto (máximo: ${PL_MAX}W)${NC}"
        echo -e "${YELLOW}  Valores sobre ${PL_MAX}W pueden dañar el hardware${NC}"
        return 1
    fi
    
    # Validar coherencia PL2 >= PL1
    if [ "$type" = "PL2" ] && [ -n "${PL1_CURRENT:-}" ] && [ "$value" -lt "$PL1_CURRENT" ]; then
        echo -e "${RED}✗ Error: PL2 (${value}W) no puede ser menor que PL1 (${PL1_CURRENT}W)${NC}"
        echo -e "${YELLOW}  PL2 es el burst a corto plazo y debe ser >= PL1${NC}"
        return 1
    fi
    
    if [ "$type" = "PL1" ] && [ -n "${PL2_CURRENT:-}" ] && [ "$PL2_CURRENT" -gt 0 ] && [ "$value" -gt "$PL2_CURRENT" ]; then
        echo -e "${YELLOW}⚠ Advertencia: PL1 (${value}W) es mayor que PL2 (${PL2_CURRENT}W)${NC}"
        echo -e "${YELLOW}  Se recomienda PL2 >= PL1. Considera ajustar PL2 también.${NC}"
        read -p "  ¿Continuar de todos modos? (s/n): " confirm
        if [ "$confirm" != "s" ] && [ "$confirm" != "S" ]; then
            return 1
        fi
    fi
    
    # Advertencia si está fuera del rango seguro
    if [ "$value" -lt $PL_SAFE_MIN ] || [ "$value" -gt $PL_SAFE_MAX ]; then
        echo -e "${YELLOW}⚠ Advertencia: TDP fuera del rango típico de laptops${NC}"
        echo -e "${YELLOW}  Rango recomendado: ${PL_SAFE_MIN}W - ${PL_SAFE_MAX}W${NC}"
        read -p "  ¿Continuar de todos modos? (s/n): " confirm
        if [ "$confirm" != "s" ] && [ "$confirm" != "S" ]; then
            return 1
        fi
    fi
    
    return 0
}

validate_time_window() {
    local value=$1
    
    if ! validate_number "$value"; then
        echo -e "${RED}✗ Error: Debe ser un número${NC}"
        return 1
    fi
    
    if [ "$value" -lt $TIME_MIN ]; then
        echo -e "${RED}✗ Error: Tiempo muy corto (mínimo: ${TIME_MIN}s)${NC}"
        return 1
    fi
    
    if [ "$value" -gt $TIME_MAX ]; then
        echo -e "${RED}✗ Error: Tiempo muy largo (máximo: ${TIME_MAX}s)${NC}"
        return 1
    fi
    
    return 0
}

validate_prochot() {
    local value=$1
    
    if ! validate_number "$value"; then
        echo -e "${RED}✗ Error: Debe ser un número${NC}"
        return 1
    fi
    
    if [ "$value" -lt $PROCHOT_TEMP_MIN ] || [ "$value" -gt $PROCHOT_TEMP_MAX ]; then
        echo -e "${RED}✗ Error: Temperatura fuera de rango${NC}"
        echo -e "${YELLOW}  Rango permitido: ${PROCHOT_TEMP_MIN}°C a ${PROCHOT_TEMP_MAX}°C${NC}"
        return 1
    fi
    
    if [ "$value" -gt "$TJMAX" ]; then
        echo -e "${YELLOW}⚠ Advertencia: ${value}°C supera el Tjmax de tu CPU (${TJMAX}°C)${NC}"
        echo -e "${YELLOW}  El CPU no puede funcionar por encima de su Tjmax sin protegerse${NC}"
        read -p "  ¿Continuar? (s/n): " confirm
        if [ "$confirm" != "s" ] && [ "$confirm" != "S" ]; then
            return 1
        fi
    fi
    
    if [ "$value" -lt 80 ]; then
        echo -e "${YELLOW}⚠ Advertencia: ${value}°C es un límite bastante bajo${NC}"
        echo -e "${YELLOW}  El CPU puede hacer throttling incluso con carga moderada${NC}"
        read -p "  ¿Continuar? (s/n): " confirm
        if [ "$confirm" != "s" ] && [ "$confirm" != "S" ]; then
            return 1
        fi
    fi
    
    return 0
}

validate_frequency() {
    local value=$1
    local type=$2  # min o max
    
    if ! validate_number "$value"; then
        echo -e "${RED}✗ Error: Debe ser un número${NC}"
        return 1
    fi
    
    if [ "$value" -lt $FREQ_MIN ]; then
        echo -e "${RED}✗ Error: Frecuencia muy baja (mínimo: ${FREQ_MIN}MHz)${NC}"
        return 1
    fi
    
    if [ "$value" -gt $FREQ_MAX ]; then
        echo -e "${RED}✗ Error: Frecuencia muy alta (máximo: ${FREQ_MAX}MHz)${NC}"
        return 1
    fi
    
    # Verificar que no exceda el máximo del hardware
    if [ "$value" -gt "$CPUINFO_MAX" ]; then
        echo -e "${YELLOW}⚠ Advertencia: Frecuencia mayor al máximo del hardware${NC}"
        echo -e "${YELLOW}  Máximo HW: ${CPUINFO_MAX}MHz, solicitado: ${value}MHz${NC}"
        echo -e "${YELLOW}  Se limitará automáticamente a ${CPUINFO_MAX}MHz${NC}"
        # Ajustar al máximo del hardware
        if [ "$type" = "max" ]; then
            echo "$CPUINFO_MAX"
            return 2  # Código especial: ajustado
        fi
    fi
    
    return 0
}

validate_frequency_range() {
    local min_freq=$1
    local max_freq=$2
    
    if [ "$min_freq" -gt "$max_freq" ]; then
        echo -e "${RED}✗ Error: Frecuencia mínima no puede ser mayor que la máxima${NC}"
        echo -e "  Mínima: ${min_freq}MHz, Máxima: ${max_freq}MHz"
        return 1
    fi
    
    if [ $((max_freq - min_freq)) -lt 100 ]; then
        echo -e "${YELLOW}⚠ Advertencia: Rango de frecuencias muy estrecho${NC}"
        echo -e "${YELLOW}  Puede limitar el rendimiento${NC}"
    fi
    
    return 0
}

# ============================================================================
# FUNCIÓN PARA MOSTRAR LÍMITES
# ============================================================================

show_limits() {
    echo -e "${BOLD}${CYAN}════════════════════════════════════════════════════════════════${NC}"
    echo -e "${BOLD}${CYAN}                    LÍMITES DE SEGURIDAD${NC}"
    echo -e "${BOLD}${CYAN}════════════════════════════════════════════════════════════════${NC}"
    echo ""
    
    echo -e "${BOLD}${YELLOW}Undervolt (mV):${NC}"
    echo -e "  Mínimo permitido:  ${RED}${UV_MIN}${NC} mV (muy peligroso)"
    echo -e "  Límite seguro:     ${GREEN}${UV_SAFE}${NC} mV"
    echo -e "  Sin undervolt:     ${GREEN}0${NC} mV"
    echo -e "  Máximo permitido:  ${RED}${UV_MAX}${NC} mV (overvolt no recomendado)"
    echo ""
    
    echo -e "${BOLD}${YELLOW}TDP / Power Limits (W):${NC}"
    echo -e "  Mínimo absoluto:   ${RED}${PL_MIN}${NC} W"
    echo -e "  Rango seguro:      ${GREEN}${PL_SAFE_MIN}${NC} - ${GREEN}${PL_SAFE_MAX}${NC} W"
    echo -e "  Máximo permitido:  ${RED}${PL_MAX}${NC} W (desktop replacement)"
    echo ""
    
    echo -e "${BOLD}${YELLOW}Time Window (s):${NC}"
    echo -e "  Mínimo:            ${GREEN}${TIME_MIN}${NC} s"
    echo -e "  Por defecto:       ${GREEN}${TIME_DEFAULT}${NC} s"
    echo -e "  Máximo:            ${GREEN}${TIME_MAX}${NC} s"
    echo ""
    
    echo -e "${BOLD}${YELLOW}Temperatura de Throttling (°C):${NC}"
    echo -e "  Tjmax de fábrica:  ${CYAN}${TJMAX}${NC} °C (temperatura máxima del CPU)"
    echo -e "  Throttling mínimo: ${RED}${PROCHOT_TEMP_MIN}${NC} °C (puede limitar mucho el rendimiento)"
    echo -e "  Throttling máximo: ${RED}${PROCHOT_TEMP_MAX}${NC} °C"
    echo -e "  Recomendado:       ${GREEN}${TJMAX}${NC} °C (valor de fábrica)"
    echo -e ""
    echo -e "  ${CYAN}Ejemplo: Si eliges 90°C, el CPU empezará a reducir velocidad${NC}"
    echo -e "  ${CYAN}al llegar a 90°C en vez de esperar a ${TJMAX}°C${NC}"
    echo ""
    
    echo -e "${BOLD}${YELLOW}Frecuencias (MHz):${NC}"
    echo -e "  Mínimo absoluto:   ${GREEN}${FREQ_MIN}${NC} MHz"
