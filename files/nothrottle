}

check_install_dep() {
    local cmd="$1" desc="$2" install_cmd="$3"
    if command -v "$cmd" >/dev/null 2>&1; then
        echo -e "    ${GREEN}✓${NC} $cmd — $desc"
    else
        echo -e "    ${YELLOW}—${NC} $cmd — $desc"
        echo -e "      ${DIM}Instalar: $install_cmd${NC}"
    fi
}

install_manpage() {
    mkdir -p "$(dirname "$INSTALL_MAN")"
    cat > "$INSTALL_MAN" << 'MANEOF'
.TH CPU-POWER-MANAGER 8 "2025" "v1.3.0" "System Administration"
.SH NAME
nothrottle \- ThrottleStop-like CPU power management for Linux
.SH SYNOPSIS
.B sudo nothrottle
.RI [ option ]
.SH DESCRIPTION
nothrottle provides a TUI and CLI interface for managing Intel CPU
power settings on Linux, similar to ThrottleStop on Windows.
.PP
Features include CPU/GPU/Cache undervolt, TDP limits (PL1/PL2),
PROCHOT temperature threshold, frequency limits with P-core/E-core
support for hybrid architectures (Alder Lake, Raptor Lake), real-time
monitoring with throttling detection, and persistent configuration
via systemd.
.SH OPTIONS
.TP
.B \-\-install
Install to /usr/local/bin/ with systemd service, man page, and desktop entry.
.TP
.B \-\-uninstall
Remove from system (configuration in /etc/nothrottle/ is preserved).
.TP
.B \-\-status
Show current hardware status and active configuration.
.TP
.B \-\-apply
Apply saved configuration (used by systemd service on boot).
.TP
.B \-\-version
Print version and exit.
.TP
.B \-\-help
Print usage information.
.SH FILES
.TP
.I /etc/nothrottle/undervolt.conf
Undervolt settings (CPU, GPU, Cache, SA, IO in mV).
.TP
.I /etc/nothrottle/power.conf
Power limits (PL1, PL2 in watts, PL1 time window, PROCHOT temperature).
.TP
.I /etc/nothrottle/frequency.conf
Frequency limits (min/max global, P-core/E-core specific).
.SH DEPENDENCIES
.B Required:
bash, coreutils, grep
.PP
.B Optional:
intel-undervolt (undervolt), msr-tools (PROCHOT), lm-sensors (temps)
.SH SAFETY
All settings have hardware-based safety limits. Undervolt is capped at
-250mV (safe: -125mV). TDP range: 5-125W. PROCHOT: 70-105°C.
Changes are applied immediately but are NOT persistent until explicitly saved.
.SH AUTHOR
Custom tool for ubuntu-advanced-install project.
.SH SEE ALSO
.BR intel-undervolt (8),
.BR tlp (8),
.BR power-profiles-daemon (8)
MANEOF
    mandb -q 2>/dev/null || true
}

