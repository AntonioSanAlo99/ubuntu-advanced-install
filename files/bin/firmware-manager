#!/bin/bash
# ══════════════════════════════════════════════════════════════════════════════
# firmware-manager — gestor de firmware CLI para fwupd
#
# Wrapper ligero sobre fwupdmgr que simplifica las operaciones comunes
# de actualización de firmware vía LVFS (Linux Vendor Firmware Service).
#
# Instalado por ubuntu-advanced-install. Instala fwupd si no está presente.
# ══════════════════════════════════════════════════════════════════════════════
set -euo pipefail

VERSION="1.0.0"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'

die()  { echo -e "${RED}✗ $1${NC}" >&2; exit 1; }
info() { echo -e "${CYAN}ℹ${NC} $1"; }
ok()   { echo -e "${GREEN}✓${NC} $1"; }
warn() { echo -e "${YELLOW}⚠${NC} $1"; }

need_root() { [ "$(id -u)" -eq 0 ] || die "Requiere root: sudo firmware-manager $*"; }

ensure_fwupd() {
    if ! command -v fwupdmgr >/dev/null 2>&1; then
        need_root "(instalar fwupd)"
        info "Instalando fwupd..."
        apt-get install -y fwupd 2>/dev/null || die "No se pudo instalar fwupd"
        ok "fwupd instalado"
    fi
    systemctl start fwupd.service 2>/dev/null || true
}

# ============================================================================
# COMANDOS
# ============================================================================

cmd_status() {
    ensure_fwupd
    echo -e "${BOLD}Dispositivos con firmware gestionable:${NC}"
    echo ""
    fwupdmgr get-devices --no-unreported-check 2>/dev/null \
        || info "No se encontraron dispositivos fwupd"
}

cmd_check() {
    ensure_fwupd
    echo -e "${BOLD}Comprobando actualizaciones de firmware...${NC}"
    echo ""
    fwupdmgr refresh --force 2>/dev/null || true
    fwupdmgr get-updates 2>/dev/null \
        && ok "Actualizaciones listadas arriba" \
        || info "No hay actualizaciones de firmware disponibles"
}

cmd_update() {
    need_root update "$@"
    ensure_fwupd
    fwupdmgr refresh --force 2>/dev/null || true

    if [ -n "${1:-}" ]; then
        info "Actualizando dispositivo: $1"
        fwupdmgr update "$1" && ok "Firmware actualizado" \
            || die "Actualización fallida"
    else
        echo -e "${BOLD}Aplicando todas las actualizaciones de firmware...${NC}"
        fwupdmgr update 2>/dev/null && ok "Firmware actualizado" \
            || info "No hay actualizaciones pendientes"
    fi
}

cmd_history() {
    ensure_fwupd
    echo -e "${BOLD}Historial de actualizaciones de firmware:${NC}"
    echo ""
    fwupdmgr get-history 2>/dev/null || info "Sin historial"
}

cmd_security() {
    ensure_fwupd
    echo -e "${BOLD}Informe de seguridad del firmware (HSI):${NC}"
    echo ""
    fwupdmgr security 2>/dev/null || info "HSI no disponible en este hardware"
}

cmd_refresh() {
    ensure_fwupd
    info "Refrescando metadatos LVFS..."
    fwupdmgr refresh --force 2>/dev/null && ok "Metadatos actualizados" \
        || warn "No se pudieron refrescar los metadatos"
}

cmd_downgrade() {
    need_root downgrade "$@"
    ensure_fwupd
    local device="${1:-}"
    [ -z "$device" ] && die "Falta ID de dispositivo: firmware-manager downgrade <id>"
    warn "Revertir firmware puede dejar el dispositivo inestable"
    read -rp "¿Continuar? (s/N): " confirm
    [[ "$confirm" =~ ^[SsYy]$ ]] || { info "Cancelado"; exit 0; }
    fwupdmgr downgrade "$device" && ok "Firmware revertido" \
        || die "Reversión fallida"
}

# ============================================================================
# HELP
# ============================================================================

cmd_help() {
    cat << 'EOF'
firmware-manager — gestor de firmware fwupd CLI

USO:
  firmware-manager <comando> [argumentos]

COMANDOS:
  status              Listar dispositivos con firmware gestionable
  check               Comprobar si hay actualizaciones de firmware disponibles
  update [id]         Aplicar actualizaciones (todas, o solo un dispositivo)
  history             Mostrar historial de actualizaciones anteriores
  security            Informe de seguridad del firmware (HSI score)
  refresh             Refrescar metadatos desde LVFS (Linux Vendor Firmware)
  downgrade <id>      Revertir firmware de un dispositivo a versión anterior

OTROS:
  help, --help, -h    Mostrar esta ayuda
  --version           Mostrar versión

NOTAS:
  - fwupd se instala automáticamente si no está presente.
  - Los comandos update y downgrade requieren root (sudo).
  - Las actualizaciones se descargan de LVFS (fwupd.org).
  - Algunos dispositivos requieren reiniciar para aplicar el firmware.
  - El ID de dispositivo se obtiene con 'firmware-manager status'.

EJEMPLOS:
  firmware-manager status                # ver dispositivos
  firmware-manager check                 # comprobar actualizaciones
  sudo firmware-manager update           # actualizar todo
  sudo firmware-manager update <id>      # actualizar un dispositivo
  firmware-manager history               # ver historial
  firmware-manager security              # ver score HSI
  sudo firmware-manager downgrade <id>   # revertir firmware
EOF
}

# ============================================================================
# DISPATCH
# ============================================================================

case "${1:-help}" in
    status)    cmd_status ;;
    check)     cmd_check ;;
    update)    cmd_update "${2:-}" ;;
    history)   cmd_history ;;
    security)  cmd_security ;;
    refresh)   cmd_refresh ;;
    downgrade) cmd_downgrade "${2:-}" ;;
    help|--help|-h) cmd_help ;;
    --version) echo "firmware-manager $VERSION" ;;
    *) die "Comando desconocido: $1 (usa 'firmware-manager help')" ;;
esac
