#!/bin/bash
# ══════════════════════════════════════════════════════════════════════════════
# kernel-manager — gestor de kernels y parámetros GRUB para Ubuntu
#
# Instalado por ubuntu-advanced-install. Gestiona kernels .deb del sistema,
# compila kernels CachyOS desde fuente, y mantiene los parámetros del kernel
# en GRUB (incluyendo los de Clear Linux configurados durante la instalación).
# ══════════════════════════════════════════════════════════════════════════════
set -euo pipefail

VERSION="1.0.0"
GRUB_FILE="/etc/default/grub"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'

die()  { echo -e "${RED}✗ $1${NC}" >&2; exit 1; }
info() { echo -e "${CYAN}ℹ${NC} $1"; }
ok()   { echo -e "${GREEN}✓${NC} $1"; }
warn() { echo -e "${YELLOW}⚠${NC} $1"; }

need_root() { [ "$(id -u)" -eq 0 ] || die "Requiere root: sudo kernel-manager $*"; }

RUNNING=$(uname -r)

# ── Parámetros del kernel por categoría ──────────────────────────────────────
# Configurados por ubuntu-advanced-install (fuente: Clear Linux + CachyOS).
# kernel-manager los conoce y puede restaurarlos si se pierden tras updates.
#
# Nivel 1: Base (escritorio optimizado)
# Nivel 2: Base + Gaming (baja latencia, mantiene seguridad)
# Nivel 3: Base + Gaming + mitigations=off (máximo rendimiento, menos seguridad)
# Nivel 4: Mínimo (quiet splash)
PARAMS_BASE="quiet splash intel_pstate=active no_timer_check page_alloc.shuffle=1 rcupdate.rcu_expedited=1 nowatchdog nmi_watchdog=0"
PARAMS_GAMING="preempt=full tsc=reliable split_lock_detect=off"
PARAMS_UNSAFE="mitigations=off"

# ============================================================================
# COMANDOS — KERNELS
# ============================================================================

cmd_list() {
    echo -e "${BOLD}Kernels instalados:${NC}"
    echo ""
    dpkg -l 'linux-image-*' 2>/dev/null | awk '/^ii/ {print $2}' \
        | sed 's/linux-image-//' | while read -r ver; do
        if [ "$ver" = "$RUNNING" ] || [ "$ver" = "unsigned-$RUNNING" ]; then
            echo -e "  ${GREEN}▸ $ver${NC}  (activo)"
        else
            echo "    $ver"
        fi
    done
    echo ""
    echo -e "${DIM}Kernel activo: $RUNNING${NC}"
}

cmd_available() {
    echo -e "${BOLD}Kernels disponibles en repos:${NC}"
    echo ""
    apt-cache search 'linux-image-' 2>/dev/null \
        | grep -E 'generic|lowlatency|cachyos' | sort -V | tail -20
}

cmd_install() {
    need_root install "$@"
    local pkg="$1"
    [[ "$pkg" == linux-image-* ]] || pkg="linux-image-$pkg"
    info "Instalando $pkg..."
    apt-get install -y "$pkg"
    update-grub 2>/dev/null || true
    ok "$pkg instalado — reinicia para activarlo"
}

cmd_remove() {
    need_root remove "$@"
    local ver="$1"
    [ "$ver" = "$RUNNING" ] && die "No puedes eliminar el kernel activo ($RUNNING)"
    info "Eliminando kernel $ver..."
    apt-get purge -y "linux-image-*${ver}*" "linux-headers-*${ver}*" \
        "linux-modules-*${ver}*" 2>/dev/null || true
    update-grub 2>/dev/null || true
    ok "Kernel $ver eliminado"
}

cmd_set_default() {
    need_root set-default "$@"
    local ver="$1"
    local entry
    entry=$(awk -F\' '/menuentry.*with Linux/ {print $2}' /boot/grub/grub.cfg 2>/dev/null \
        | grep "$ver" | head -1)
    [ -z "$entry" ] && die "No se encontró entrada GRUB para '$ver'"

    local submenu
    submenu=$(awk -F\' '/submenu/ {print $2; exit}' /boot/grub/grub.cfg 2>/dev/null)
    [ -n "$submenu" ] && grub-set-default "${submenu}>${entry}" || grub-set-default "$entry"

    sed -i 's/^GRUB_DEFAULT=.*/GRUB_DEFAULT=saved/' "$GRUB_FILE" 2>/dev/null || true
    update-grub 2>/dev/null || true
    ok "Kernel por defecto: $ver"
}

cmd_cleanup() {
    need_root cleanup
    info "Eliminando kernels antiguos (apt autoremove)..."
    apt-get autoremove --purge -y 2>/dev/null || true
    update-grub 2>/dev/null || true
    ok "Limpieza completada"
}

cmd_cachyos() {
    need_root cachyos
    echo -e "${BOLD}Compilar e instalar kernel CachyOS${NC}"
    echo ""
    echo "  Scheduler:"
    echo "    1) BORE  — mejor respuesta interactiva (recomendado gaming)"
    echo "    2) EEVDF — EEVDF stock optimizado por CachyOS"
    echo ""
    read -rp "  Opción [1]: " sched_opt
    local sched_name="bore"
    [ "${sched_opt:-1}" = "2" ] && sched_name="eevdf"

    info "Instalando dependencias de compilación..."
    apt-get install -y git build-essential bc kmod cpio flex libncurses-dev \
        libelf-dev libssl-dev dwarves bison lz4 zstd wget >/dev/null 2>&1

    local build_dir
    build_dir=$(mktemp -d /tmp/cachyos-kernel.XXXXXX)
    cd "$build_dir"

    info "Clonando fuentes CachyOS..."
    git clone --depth 1 https://github.com/CachyOS/linux-cachyos.git
    cd linux-cachyos
    local variant_dir="linux-cachyos"
    [ "$sched_name" = "bore" ] && [ -d "linux-cachyos-bore" ] && variant_dir="linux-cachyos-bore"
    cd "$variant_dir"

    local kver
    kver=$(grep -oP '^pkgver=\K.*' PKGBUILD 2>/dev/null || echo "")
    [ -z "$kver" ] && die "No se pudo extraer versión del PKGBUILD"

    local kmajor=${kver%%.*}
    info "Descargando kernel $kver..."
    wget -q "https://cdn.kernel.org/pub/linux/kernel/v${kmajor}.x/linux-${kver}.tar.xz" \
        || die "Descarga fallida"
    tar xf "linux-${kver}.tar.xz"
    cd "linux-${kver}"

    info "Aplicando parches CachyOS..."
    for p in ../*.patch; do
        [ -f "$p" ] && patch -Np1 -i "$p" 2>/dev/null && echo "  ✓ $(basename "$p")" || true
    done
    [ -f ../config ] && cp ../config .config || make olddefconfig

    scripts/config --set-val CONFIG_HZ 1000 2>/dev/null || true
    scripts/config --enable CONFIG_PREEMPT 2>/dev/null || true
    scripts/config --enable CONFIG_TCP_CONG_BBR 2>/dev/null || true
    scripts/config --set-str CONFIG_DEFAULT_TCP_CONG "bbr" 2>/dev/null || true
    scripts/config --enable CONFIG_SCHED_CLASS_EXT 2>/dev/null || true
    [ "$sched_name" = "bore" ] && scripts/config --enable CONFIG_SCHED_BORE 2>/dev/null || true
    make olddefconfig

    local nproc
    nproc=$(nproc)
    info "Compilando con $nproc hilos (20-60 min)..."
    make -j"$nproc" deb-pkg LOCALVERSION="-cachyos-${sched_name}" 2>&1 | tail -5

    info "Instalando..."
    cd ..
    dpkg -i linux-headers-*.deb linux-image-*.deb 2>/dev/null || true
    update-grub 2>/dev/null || true

    cd /; rm -rf "$build_dir"
    ok "Kernel CachyOS ($sched_name) instalado — reinicia para activarlo"
}

# ============================================================================
# COMANDOS — PARÁMETROS GRUB
# ============================================================================

_get_cmdline() {
    grep '^GRUB_CMDLINE_LINUX_DEFAULT=' "$GRUB_FILE" 2>/dev/null \
        | sed 's/^GRUB_CMDLINE_LINUX_DEFAULT="//' | sed 's/"$//' || echo ""
}

cmd_params() {
    echo -e "${BOLD}Parámetros actuales del kernel (GRUB_CMDLINE_LINUX_DEFAULT):${NC}"
    echo ""
    local current
    current=$(_get_cmdline)
    if [ -z "$current" ]; then
        warn "Sin parámetros configurados"
    else
        echo "  $current"
    fi
    echo ""
    echo -e "${BOLD}Estado de parámetros gestionados:${NC}"
    echo ""
    echo -e "  ${CYAN}Base (Clear Linux / escritorio optimizado):${NC}"
    for p in $PARAMS_BASE; do
        local key="${p%%=*}"
        if echo "$current" | grep -qw "$key"; then
            echo -e "    ${GREEN}✓${NC} $p"
        else
            echo -e "    ${RED}✗${NC} $p  ${DIM}(ausente)${NC}"
        fi
    done
    echo ""
    echo -e "  ${CYAN}Gaming (baja latencia, mantiene seguridad):${NC}"
    for p in $PARAMS_GAMING; do
        local key="${p%%=*}"
        if echo "$current" | grep -qw "$key"; then
            echo -e "    ${GREEN}✓${NC} $p"
        else
            echo -e "    ${DIM}·${NC} $p  ${DIM}(no aplicado)${NC}"
        fi
    done
    echo ""
    echo -e "  ${CYAN}Rendimiento inseguro (desactiva protecciones CPU):${NC}"
    for p in $PARAMS_UNSAFE; do
        local key="${p%%=*}"
        if echo "$current" | grep -qw "$key"; then
            echo -e "    ${YELLOW}⚠${NC} $p  ${DIM}(activo — seguridad reducida)${NC}"
        else
            echo -e "    ${DIM}·${NC} $p  ${DIM}(no aplicado)${NC}"
        fi
    done
}

cmd_params_restore() {
    need_root params-restore
    info "Restaurando parámetros base (Clear Linux)..."
    local current
    current=$(_get_cmdline)
    local new="$current"
    for param in $PARAMS_BASE; do
        local key="${param%%=*}"
        echo "$new" | grep -qw "$key" || new="$new $param"
    done
    new=$(echo "$new" | xargs)
    sed -i "s|^GRUB_CMDLINE_LINUX_DEFAULT=.*|GRUB_CMDLINE_LINUX_DEFAULT=\"$new\"|" "$GRUB_FILE"
    update-grub 2>/dev/null || true
    ok "Parámetros base restaurados"
}

cmd_params_gaming() {
    need_root params-gaming
    info "Aplicando parámetros gaming (baja latencia, mantiene seguridad)..."
    echo "  preempt=full          — preemption completa"
    echo "  tsc=reliable          — evita calibración TSC innecesaria"
    echo "  split_lock_detect=off — evita penalización de split locks"
    echo ""

    local current
    current=$(_get_cmdline)
    local new="$current"
    for param in $PARAMS_GAMING; do
        local key="${param%%=*}"
        echo "$new" | grep -qw "$key" || new="$new $param"
    done
    new=$(echo "$new" | xargs)
    sed -i "s|^GRUB_CMDLINE_LINUX_DEFAULT=.*|GRUB_CMDLINE_LINUX_DEFAULT=\"$new\"|" "$GRUB_FILE"
    update-grub 2>/dev/null || true
    ok "Parámetros gaming aplicados — reinicia para activarlos"
}

cmd_params_unsafe() {
    need_root params-unsafe
    warn "Esto desactiva protecciones de seguridad del procesador:"
    echo "  mitigations=off — desactiva Spectre/Meltdown/MDS (+5-10% FPS)"
    echo ""
    echo "  Tu sistema será vulnerable a ataques de canal lateral."
    echo "  Solo recomendado en máquinas de gaming dedicadas."
    echo ""
    read -rp "¿Aplicar? (escribe SI en mayúsculas): " confirm
    [ "$confirm" = "SI" ] || { info "Cancelado"; return; }

    local current
    current=$(_get_cmdline)
    local new="$current"
    for param in $PARAMS_UNSAFE; do
        local key="${param%%=*}"
        echo "$new" | grep -qw "$key" || new="$new $param"
    done
    new=$(echo "$new" | xargs)
    sed -i "s|^GRUB_CMDLINE_LINUX_DEFAULT=.*|GRUB_CMDLINE_LINUX_DEFAULT=\"$new\"|" "$GRUB_FILE"
    update-grub 2>/dev/null || true
    ok "mitigations=off aplicado — reinicia para activarlo"
}

cmd_params_add() {
    need_root params-add "$@"
    local param="$1"
    local current
    current=$(_get_cmdline)
    local key="${param%%=*}"
    if echo "$current" | grep -qw "$key"; then
        warn "'$key' ya presente — usa 'params-remove $key' primero para cambiarlo"
        return
    fi
    local new
    new=$(echo "$current $param" | xargs)
    sed -i "s|^GRUB_CMDLINE_LINUX_DEFAULT=.*|GRUB_CMDLINE_LINUX_DEFAULT=\"$new\"|" "$GRUB_FILE"
    update-grub 2>/dev/null || true
    ok "Parámetro '$param' añadido"
}

cmd_params_remove() {
    need_root params-remove "$@"
    local key="$1"
    local current
    current=$(_get_cmdline)
    local new
    new=$(echo "$current" | sed -E "s/\b${key}(=[^ ]*)?\b//g" | xargs)
    sed -i "s|^GRUB_CMDLINE_LINUX_DEFAULT=.*|GRUB_CMDLINE_LINUX_DEFAULT=\"$new\"|" "$GRUB_FILE"
    update-grub 2>/dev/null || true
    ok "Parámetro '$key' eliminado"
}

# ============================================================================
# HELP
# ============================================================================

cmd_help() {
    cat << 'EOF'
kernel-manager — gestor de kernels y parámetros GRUB para Ubuntu

USO:
  kernel-manager <comando> [argumentos]

GESTIÓN DE KERNELS:
  list                  Listar kernels instalados (marca el activo)
  available             Buscar kernels disponibles en repos apt
  install <paquete>     Instalar kernel (ej: 6.8.0-45-generic)
  remove <versión>      Eliminar kernel (no permite eliminar el activo)
  set-default <ver>     Cambiar kernel por defecto en GRUB
  cleanup               Eliminar kernels antiguos (apt autoremove)
  cachyos               Compilar e instalar kernel CachyOS (BORE/EEVDF)

PARÁMETROS DEL KERNEL (GRUB):
  params                Mostrar parámetros actuales y estado de los gestionados
  params-restore        Restaurar parámetros base de la instalación (Clear Linux)
  params-gaming         Aplicar parámetros gaming seguros (preempt, tsc, split_lock)
  params-unsafe         Aplicar mitigations=off (⚠ reduce seguridad)
  params-add <param>    Añadir un parámetro (ej: threadirqs)
  params-remove <key>   Eliminar un parámetro por nombre (ej: mitigations)

OTROS:
  help, --help, -h      Mostrar esta ayuda
  --version             Mostrar versión

NIVELES DE PARÁMETROS (configurados durante la instalación):

  Nivel 1 — Base (Clear Linux / escritorio optimizado):
    quiet splash intel_pstate=active no_timer_check
    page_alloc.shuffle=1 rcupdate.rcu_expedited=1 nowatchdog nmi_watchdog=0

  Nivel 2 — Base + Gaming (baja latencia, mantiene seguridad):
    Añade: preempt=full tsc=reliable split_lock_detect=off

  Nivel 3 — Base + Gaming + mitigations=off (máximo rendimiento):
    Añade: mitigations=off (⚠ desactiva Spectre/Meltdown, +5-10% FPS)

  Nivel 4 — Mínimo: quiet splash

  Si una actualización del sistema sobreescribe los parámetros, usa
  'params-restore' para recuperar los base sin tocar gaming ni custom.

EJEMPLOS:
  kernel-manager list                    # ver kernels instalados
  kernel-manager params                  # ver parámetros actuales
  sudo kernel-manager params-restore     # restaurar parámetros base
  sudo kernel-manager params-gaming      # aplicar gaming seguros
  sudo kernel-manager params-unsafe      # aplicar mitigations=off
  sudo kernel-manager params-add threadirqs  # añadir parámetro custom
  sudo kernel-manager params-remove mitigations  # quitar mitigations
  sudo kernel-manager cachyos            # compilar kernel CachyOS
  sudo kernel-manager install 6.8.0-45-generic
  sudo kernel-manager set-default 6.8.0-45-generic-cachyos-bore
EOF
}

# ============================================================================
# DISPATCH
# ============================================================================

case "${1:-help}" in
    list)           cmd_list ;;
    available)      cmd_available ;;
    install)        [ -z "${2:-}" ] && die "Falta paquete: kernel-manager install <paquete>"; cmd_install "$2" ;;
    remove)         [ -z "${2:-}" ] && die "Falta versión: kernel-manager remove <versión>"; cmd_remove "$2" ;;
    set-default)    [ -z "${2:-}" ] && die "Falta versión: kernel-manager set-default <ver>"; cmd_set_default "$2" ;;
    cleanup)        cmd_cleanup ;;
    cachyos)        cmd_cachyos ;;
    params)         cmd_params ;;
    params-restore) cmd_params_restore ;;
    params-gaming)  cmd_params_gaming ;;
    params-unsafe)  cmd_params_unsafe ;;
    params-add)     [ -z "${2:-}" ] && die "Falta parámetro: kernel-manager params-add <param>"; cmd_params_add "$2" ;;
    params-remove)  [ -z "${2:-}" ] && die "Falta clave: kernel-manager params-remove <key>"; cmd_params_remove "$2" ;;
    help|--help|-h) cmd_help ;;
    --version)      echo "kernel-manager $VERSION" ;;
    *) die "Comando desconocido: $1 (usa 'kernel-manager help')" ;;
esac
