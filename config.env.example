# ============================================================================
# CONFIGURACIÓN UBUNTU ADVANCED INSTALL
# ============================================================================
# Este archivo contiene todas las variables de configuración.
# Copia este archivo a config.env y ajusta los valores.
#
# cp config.env.example config.env
# nano config.env
#
# Luego ejecuta: sudo ./install.sh --auto

# === SISTEMA BASE ===
UBUNTU_VERSION="noble"
HOSTNAME="ubuntu"
USERNAME="user"
USER_PASSWORD="changeme"
ROOT_PASSWORD="changeme"

# === LOCALIZACIÓN ===
TIMEZONE="Europe/Madrid"
LOCALE="es_ES.UTF-8"
KEYBOARD_LAYOUT="es"

# === HARDWARE ===
IS_LAPTOP="false"          # true para laptops
HAS_WIFI="true"            # true para instalar WiFi
HAS_BLUETOOTH="true"       # true para instalar Bluetooth

# === DISCO ===
TARGET="/mnt/ubuntu"
TARGET_DISK="/dev/sda"
DUAL_BOOT="false"
UBUNTU_SIZE_GB="100"        # GiB para Ubuntu en modo dual boot
SWAP_GIB=""                 # GiB de partición swap (vacío = calcular automáticamente según RAM)

# === COMPONENTES ===
INSTALL_GNOME="true"
INSTALL_MULTIMEDIA="true"
INSTALL_DEVELOPMENT="false"
INSTALL_GAMING="false"
# INSTALL_PROTONPLUS solo tiene efecto si INSTALL_GAMING=true
INSTALL_PROTONPLUS="true"


# === GNOME — Personalización ===
GDM_AUTOLOGIN="false"
GNOME_OPTIMIZE_MEMORY="true"
GNOME_TRANSPARENT_THEME="true"
GNOME_DOCK="ubuntu-dock"          # ubuntu-dock | dash-to-panel

# === MULTIMEDIA ===
INSTALL_SPOTIFY="s"             # s/n
INSTALL_CINE="true"             # Compilar Cine desde fuente (reproductor GTK4 + mpv)

# === DESARROLLO ===
INSTALL_VSCODE="s"              # s/n
NODEJS_OPTION="2"               # 1=No instalar, 2=LTS NodeSource
INSTALL_RUST="n"                # s/n
INSTALL_TOPGRADE="s"            # s/n

# === GAMING ===


# === OPTIMIZACIONES ===
MINIMIZE_SYSTEMD="true"
ENABLE_SECURITY="false"             # Solo editable en config.env
AUTO_UPDATE_CHOICE="1"          # 1=Solo seguridad, 2=Todas, 3=No configurar

# === LAPTOP (si IS_LAPTOP="true") ===
POWER_MANAGER="1"               # 1=power-profiles-daemon, 2=TLP
INSTALL_NOTHROTTLE="false"      # true=instalar nothrottle (Intel 8th-14th Gen)
