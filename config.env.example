# ══════════════════════════════════════════════════════════════════════════════
# ubuntu-advanced-install — config.env
#
# Copia este fichero y edítalo:
#   cp config.env.example config.env
#   nano config.env
#   sudo ./install.sh --auto
#
# O genera uno interactivamente:
#   sudo ./install.sh --config
#
# Las contraseñas no se almacenan en este fichero.
# Se piden interactivamente durante la instalación.
# ══════════════════════════════════════════════════════════════════════════════

# === SISTEMA BASE ===
UBUNTU_VERSION="noble"          # focal | jammy | noble | questing | resolute
TARGET_DISK="/dev/vda"          # Disco destino (/dev/sda, /dev/nvme0n1, etc.)
TARGET="/mnt/ubuntu"            # Punto de montaje del chroot
HOSTNAME="ubuntu"
USERNAME="antonio"

# === HARDWARE ===
IS_LAPTOP="false"               # true | false
HAS_WIFI="true"                 # true | false
HAS_BLUETOOTH="true"            # true | false

# === COMPONENTES ===
INSTALL_GNOME="true"            # true | false
INSTALL_MULTIMEDIA="true"       # true | false
INSTALL_DEVELOPMENT="false"     # true | false
INSTALL_GAMING="false"          # true | false
INSTALL_PROTONPLUS="false"      # true | false (solo si INSTALL_GAMING=true)

# === GNOME — Personalización ===
GDM_AUTOLOGIN="true"            # true | false
GNOME_OPTIMIZE_MEMORY="true"    # true | false
GNOME_TRANSPARENT_THEME="true"  # true | false
GNOME_DOCK="dash-to-panel"      # ubuntu-dock | dash-to-panel

# === MULTIMEDIA ===
INSTALL_SPOTIFY="s"             # s | n

# === DESARROLLO ===
INSTALL_VSCODE="s"              # s | n
NODEJS_OPTION="2"               # 1=No instalar | 2=LTS NodeSource
INSTALL_RUST="n"                # s | n
INSTALL_TOPGRADE="s"            # s | n

# === GAMING ===
GPU_MANUAL="9"                  # 1=AMD 2=Intel 3=Intel+NVIDIA 4=Intel+AMD
                                # 5=AMD+AMD 6=AMD+NVIDIA 7=NVIDIA 8=VM 9=Auto

# === OPTIMIZACIONES ===
MINIMIZE_SYSTEMD="true"         # true | false
ENABLE_SECURITY="false"         # true | false
AUTO_UPDATE_CHOICE="1"          # 1=Solo seguridad | 2=Todas | 3=No configurar
INSTALL_STORAGE_OPT="false"     # true | false
STORAGE_DISK_TYPE=""             # nvme | ssd | hdd | emmc (solo si INSTALL_STORAGE_OPT=true)

# === LAPTOP (solo si IS_LAPTOP=true) ===
POWER_MANAGER="1"               # 1=power-profiles-daemon | 2=TLP
INSTALL_NOTHROTTLE="false"      # true | false (Intel 8th-14th Gen throttling fix)

# === OPCIONES AVANZADAS ===
DUAL_BOOT="false"               # true | false
UBUNTU_SIZE_GB="50"             # GiB para Ubuntu en modo dual boot
